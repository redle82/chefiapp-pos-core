  "description": "ChefIApp Desktop — Electron shell for TPV/KDS",
  "author": "Goldmonkey Empire",
  "license": "ISC",
  "main": "dist-electron/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:electron": "tsc -p tsconfig.json",
