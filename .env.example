# ==============================================================================
# CHEFIAPP POS CORE - Environment Variables
# ==============================================================================
# COPY this file to .env and fill in your values
# NEVER commit .env to version control
# ==============================================================================

# ------------------------------------------------------------------------------
# Stripe API Keys (backend / webhook)
# ------------------------------------------------------------------------------
# Get from: https://dashboard.stripe.com/test/apikeys
# Frontend (merchant-portal): VITE_STRIPE_* → ver merchant-portal/.env.example
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# ------------------------------------------------------------------------------
# Database Configuration
# ------------------------------------------------------------------------------
# PostgreSQL connection settings
POSTGRES_USER=test_user
POSTGRES_PASSWORD=test_password
POSTGRES_DB=chefiapp_core_test

# Database URL (auto-constructed in docker-compose, override if needed)
# DATABASE_URL=postgresql://test_user:test_password@localhost:5432/chefiapp_core_test

# Database port mapping (if 5432 is already taken on your machine)
DB_PORT=5432

# ------------------------------------------------------------------------------
# Service Ports
# ------------------------------------------------------------------------------
# Webhook server (Stripe webhooks)
WEBHOOK_PORT=3000

# Billing webhook server
BILLING_WEBHOOK_PORT=3099

# Subscription management UI
SUBSCRIPTION_UI_PORT=4310

# Web module API server
WEB_MODULE_PORT=4320

# ------------------------------------------------------------------------------
# Optional: Database Management Tools
# ------------------------------------------------------------------------------
# pgAdmin (only starts with: docker compose --profile tools up)
PGADMIN_PORT=5050
PGADMIN_EMAIL=admin@chefiapp.local
PGADMIN_PASSWORD=admin

# ------------------------------------------------------------------------------
# Application Configuration
# ------------------------------------------------------------------------------
# Node environment (development, production, test)
NODE_ENV=production

# Enable migrations on startup
RUN_MIGRATIONS=false

# ------------------------------------------------------------------------------
# Testing & Development
# ------------------------------------------------------------------------------
# Failpoint Testing (optional - for chaos engineering)
FAILPOINT_ENABLED=false
FAILPOINT_PROB=0.01

# World Test Modes (optional - for load testing)
# WORLD_FULL=true
# WORLD_STRESS=true

# ------------------------------------------------------------------------------
# Build Information (optional - for Docker build)
# ------------------------------------------------------------------------------
# BUILD_DATE=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
# VCS_REF=$(git rev-parse --short HEAD)
# VERSION=1.0.0
