  {
    "id": "TC009",
    "title": "order total calculation immutability",
    "description": "Test that order total_cents is calculated correctly when order is locked and remains immutable. Verify: total = sum(items.quantity * items.price_snapshot_cents), total does not change after LOCKED, and total is stored correctly. This validates financial immutability guarantee.",
    "requirement": "R002: Order Lifecycle",
    "setup": [
      {
        "step": "create_test_session",
        "description": "Create a test session",
        "endpoint": "POST /api/auth/request-magic-link",
        "body": { "email": "test@chefiapp.test" },
        "extract": "dev_token",
        "then": {
          "endpoint": "GET /api/auth/verify-magic-link?token={dev_token}",
          "extract": "session_token",
          "store_as": "SESSION_TOKEN"
        }
      },
      {
        "step": "create_order_with_multiple_items",
        "description": "Create order with items for total calculation",
        "endpoint": "POST /api/orders",
        "headers": { "x-chefiapp-token": "{SESSION_TOKEN}" },
        "body": {
          "tableId": "test-table-1",
          "items": [
            {
              "product_id": "prod-test-1",
              "quantity": 2,
              "price_snapshot_cents": 1500
            },
            {
              "product_id": "prod-test-2",
              "quantity": 3,
              "price_snapshot_cents": 2000
            },
            {
              "product_id": "prod-test-3",
              "quantity": 1,
              "price_snapshot_cents": 500
            }
          ],
          "restaurantId": "test-rest-1"
        },
        "extract": "id",
        "store_as": "ORDER_ID"
      }
    ],
    "headers": {
      "x-chefiapp-token": "{SESSION_TOKEN}"
    },
    "endpoint": "POST /api/orders/{orderId}/lock",
    "url_params": {
      "orderId": "{ORDER_ID}"
    },
    "expected_response": {
      "status": 200,
      "body_contains": ["total_cents", "state", "LOCKED"],
      "total_cents": 9500
    },
    "note": "IMPORTANT: Use POST /api/orders/{orderId}/lock endpoint. Do NOT use PATCH with {\"action\": \"lock\"}. The lock endpoint is a dedicated POST endpoint, not a PATCH action.",
    "validation_steps": [
      {
        "step": "verify_total_calculation",
        "description": "Verify total = (2*1500) + (3*2000) + (1*500) = 9500",
        "expected_total_cents": 9500
      },
      {
        "step": "verify_total_immutability",
        "description": "After lock, total should not change",
        "endpoint": "GET /api/orders/{ORDER_ID}",
        "headers": { "x-chefiapp-token": "{SESSION_TOKEN}" },
        "expected_total_cents": 9500
      }
    ],
    "teardown": []
  },
  {
    "id": "TC010",
    "title": "order state machine transitions",
    "description": "Test that order state transitions follow the correct state machine: OPEN → LOCKED → CLOSED. Verify invalid transitions are rejected (e.g., CLOSED → OPEN, LOCKED → OPEN). This validates state machine integrity.",
    "requirement": "R002: Order Lifecycle",
    "setup": [
      {
        "step": "create_test_session",
        "description": "Create a test session",
        "endpoint": "POST /api/auth/request-magic-link",
        "body": { "email": "test@chefiapp.test" },
        "extract": "dev_token",
        "then": {
          "endpoint": "GET /api/auth/verify-magic-link?token={dev_token}",
          "extract": "session_token",
          "store_as": "SESSION_TOKEN"
        }
      },
      {
        "step": "create_order",
        "description": "Create a test order",
        "endpoint": "POST /api/orders",
        "headers": { "x-chefiapp-token": "{SESSION_TOKEN}" },
        "body": {
          "tableId": "test-table-1",
          "items": [
            {
              "product_id": "prod-test-1",
              "quantity": 1,
              "price_snapshot_cents": 1000
            }
          ],
          "restaurantId": "test-rest-1"
        },
        "extract": "id",
        "store_as": "ORDER_ID"
      }
    ],
    "headers": {
      "x-chefiapp-token": "{SESSION_TOKEN}"
    },
    "validation_steps": [
      {
        "step": "verify_initial_state_open",
        "description": "Order should start in OPEN state",
        "endpoint": "GET /api/orders/{ORDER_ID}",
        "headers": { "x-chefiapp-token": "{SESSION_TOKEN}" },
        "expected_state": "OPEN"
      },
      {
        "step": "transition_open_to_locked",
        "description": "OPEN → LOCKED should succeed",
        "endpoint": "POST /api/orders/{ORDER_ID}/lock",
        "headers": { "x-chefiapp-token": "{SESSION_TOKEN}" },
        "expected_state": "LOCKED",
        "expected_status": 200
      },
      {
        "step": "verify_locked_state",
        "description": "Order should be in LOCKED state",
        "endpoint": "GET /api/orders/{ORDER_ID}",
        "headers": { "x-chefiapp-token": "{SESSION_TOKEN}" },
        "expected_state": "LOCKED"
      },
      {
        "step": "transition_locked_to_closed",
        "description": "LOCKED → CLOSED should succeed",
        "endpoint": "POST /api/orders/{ORDER_ID}/close",
        "headers": { "x-chefiapp-token": "{SESSION_TOKEN}" },
        "expected_state": "CLOSED",
        "expected_status": 200
      },
      {
        "step": "verify_closed_state",
        "description": "Order should be in CLOSED state",
        "endpoint": "GET /api/orders/{ORDER_ID}",
        "headers": { "x-chefiapp-token": "{SESSION_TOKEN}" },
        "expected_state": "CLOSED"
      },
      {
        "step": "reject_invalid_transition_closed_to_open",
        "description": "CLOSED → OPEN should be rejected",
        "endpoint": "PATCH /api/orders/{ORDER_ID}",
        "headers": { "x-chefiapp-token": "{SESSION_TOKEN}" },
        "body": { "state": "OPEN" },
        "expected_status": 400,
        "expected_error": "CLOSED"
      }
    ],
    "teardown": []
  }
]
