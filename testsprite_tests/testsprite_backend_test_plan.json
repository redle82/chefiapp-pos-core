  {
    "id": "TC003",
    "title": "post api orders create order",
    "description": "Test that POST /api/orders creates a new order in OPEN state. Verify the order is created with correct initial state, table_id is set, and order_id is returned. This validates the order creation workflow.",
    "requirement": "R002: Order Lifecycle",
    "setup": [
      {
        "step": "create_test_session",
        "description": "Create a test session by requesting magic link and verifying token",
        "endpoint": "POST /api/auth/request-magic-link",
        "body": { "email": "test@chefiapp.test" },
        "extract": "dev_token",
        "then": {
          "endpoint": "GET /api/auth/verify-magic-link?token={dev_token}",
          "extract": "session_token",
          "store_as": "SESSION_TOKEN"
        }
      }
    ],
    "headers": {
      "x-chefiapp-token": "{SESSION_TOKEN}"
    },
    "teardown": []
  },
  {
    "id": "TC004",
    "title": "patch api orders update order items",
    "description": "Test that PATCH /api/orders/{orderId} allows adding items to an OPEN order. Verify items are added correctly, order remains in OPEN state, and updates are persisted. This validates order modification before locking.",
    "requirement": "R002: Order Lifecycle",
    "setup": [
      {
        "step": "create_test_session",
        "description": "Create a test session",
        "endpoint": "POST /api/auth/request-magic-link",
        "body": { "email": "test@chefiapp.test" },
        "extract": "dev_token",
        "then": {
          "endpoint": "GET /api/auth/verify-magic-link?token={dev_token}",
          "extract": "session_token",
          "store_as": "SESSION_TOKEN"
        }
      },
      {
        "step": "create_test_order",
        "description": "Create a test order in OPEN state",
        "endpoint": "POST /api/orders",
        "headers": { "x-chefiapp-token": "{SESSION_TOKEN}" },
        "body": {
          "tableId": "test-table-1",
          "items": [],
          "restaurantId": "test-rest-1"
        },
        "extract": "id",
        "store_as": "ORDER_ID"
      }
    ],
    "headers": {
      "x-chefiapp-token": "{SESSION_TOKEN}"
    },
    "body": {
      "items": [
        {
          "product_id": "prod-test-1",
          "quantity": 2,
          "price_snapshot_cents": 1500
        }
      ]
    },
    "url_params": {
      "orderId": "{ORDER_ID}"
    },
    "teardown": []
  },
  {
    "id": "TC005",
    "title": "post api orders lock order",
    "description": "Test that an order can be locked (OPEN → LOCKED transition). Verify that when order is locked: total is calculated, state changes to LOCKED, and order becomes immutable (no more items can be added). This validates the order finalization process.",
    "requirement": "R002: Order Lifecycle",
    "setup": [
      {
        "step": "create_test_session",
        "description": "Create a test session",
        "endpoint": "POST /api/auth/request-magic-link",
        "body": { "email": "test@chefiapp.test" },
        "extract": "dev_token",
        "then": {
          "endpoint": "GET /api/auth/verify-magic-link?token={dev_token}",
          "extract": "session_token",
          "store_as": "SESSION_TOKEN"
        }
      },
      {
        "step": "create_test_order_with_items",
        "description": "Create a test order with items",
        "endpoint": "POST /api/orders",
        "headers": { "x-chefiapp-token": "{SESSION_TOKEN}" },
        "body": {
          "tableId": "test-table-1",
          "items": [
            {
              "product_id": "prod-test-1",
              "quantity": 2,
              "price_snapshot_cents": 1500
            },
            {
              "product_id": "prod-test-2",
              "quantity": 1,
              "price_snapshot_cents": 2000
            }
          ],
          "restaurantId": "test-rest-1"
        },
        "extract": "id",
        "store_as": "ORDER_ID"
      }
    ],
    "headers": {
      "x-chefiapp-token": "{SESSION_TOKEN}"
    },
    "endpoint": "POST /api/orders/{orderId}/lock",
    "url_params": {
      "orderId": "{ORDER_ID}"
    },
    "expected_response": {
      "status": 200,
      "body_contains": ["state", "LOCKED", "total_cents"],
      "total_cents": 5000
    },
    "teardown": []
  },
  {
