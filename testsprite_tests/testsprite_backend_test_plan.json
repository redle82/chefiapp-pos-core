      {
        "step": "lock_order",
        "description": "Lock the order",
        "endpoint": "POST /api/orders/{ORDER_ID}/lock",
        "headers": { "x-chefiapp-token": "{SESSION_TOKEN}" }
      }
    ],
    "headers": {
      "x-chefiapp-token": "{SESSION_TOKEN}"
    },
    "body": {
      "items": [
        {
          "product_id": "prod-test-2",
          "quantity": 1,
          "price_snapshot_cents": 2000
        }
      ]
    },
    "url_params": {
      "orderId": "{ORDER_ID}"
    },
    "expected_response": {
      "status": 400,
      "body_contains": ["error", "LOCKED", "immutable"]
    },
    "teardown": []
