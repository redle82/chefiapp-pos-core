# ==============================================================================
# CHEFIAPP POS CORE — Staging Environment
# ==============================================================================
# Copy to .env on the staging server.
# All values marked CHANGE_ME must be replaced before deploy.
# ==============================================================================

# --- Stripe (test mode for staging) ---
STRIPE_PUBLISHABLE_KEY=pk_test_CHANGE_ME
STRIPE_SECRET_KEY=sk_test_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME

# --- Database ---
POSTGRES_USER=chefiapp_staging
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=chefiapp_staging
DB_PORT=5432

# --- Service Ports ---
WEBHOOK_PORT=3000
BILLING_WEBHOOK_PORT=3099
SUBSCRIPTION_UI_PORT=4310
WEB_MODULE_PORT=4320

# --- Keycloak ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
KEYCLOAK_PORT=8080
KC_HOSTNAME=auth.staging.chefiapp.com
VITE_KEYCLOAK_URL=https://auth.staging.chefiapp.com
VITE_KEYCLOAK_REALM=chefiapp
VITE_KEYCLOAK_CLIENT_ID=merchant-portal

# --- Application ---
NODE_ENV=production
RUN_MIGRATIONS=false
WEB_MODULE_RESTAURANT_ID=a0000000-0000-0000-0000-000000000100

# --- Pilot restaurant ---
# After first deploy, run:
#   docker exec -i chefiapp-db psql -U chefiapp_staging -d chefiapp_staging < scripts/seed-pilot.sql
