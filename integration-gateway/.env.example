# Integration Gateway Configuration

# Server
PORT=4320
NODE_ENV=development

# Supabase (Backend API)
SUPABASE_URL=http://localhost:3000
SUPABASE_ANON_KEY=your-anon-key-here

# Payment Processor API Keys
SUMUP_API_KEY=your-sumup-api-key
SUMUP_ACCESS_TOKEN=your-sumup-oauth-access-token
SUMUP_MERCHANT_CODE=your-sumup-merchant-code
SUMUP_API_BASE_URL=https://api.sumup.com
SUMUP_PIX_DEFAULT_COUNTRY=BR
SUMUP_PIX_DEFAULT_CURRENCY=BRL
STRIPE_API_KEY=your-stripe-api-key

# Logging
LOG_LEVEL=info
