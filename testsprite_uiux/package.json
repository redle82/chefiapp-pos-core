{
  "name": "testsprite-uiux",
  "version": "1.0.0",
  "description": "UI/UX Audit Test Suite for ChefIApp POS Core",
  "type": "module",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:smoke": "playwright test specs/uiux_audit.spec.ts --grep @smoke",
    "test:screenshots": "playwright test specs/uiux_audit.spec.ts --grep @screenshots",
    "test:a11y": "playwright test specs/uiux_audit.spec.ts --grep @a11y",
    "test:states": "playwright test specs/uiux_audit.spec.ts --grep @states",
    "report": "playwright show-report",
    "report:generate": "node scripts/generate-reports.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@axe-core/playwright": "^4.10.0",
    "csv-writer": "^1.6.0"
  }
}

