{
    "id": "cash-register",
    "version": "1.0.0",
    "initial": "CLOSED",
    "states": {
        "CLOSED": {
            "on": {
                "OPEN": {
                    "target": "OPEN",
                    "guards": [
                        "canOpenCashRegister"
                    ]
                }
            }
        },
        "OPEN": {
            "on": {
                "CLOSE": {
                    "target": "CLOSED",
                    "guards": [
                        "canCloseCashRegister",
                        "noOpenOrders"
                    ]
                },
                "DROP": {
                    "target": "OPEN",
                    "guards": [
                        "hasSufficientBalance"
                    ]
                },
                "ADD": {
                    "target": "OPEN"
                },
                "SALE": {
                    "target": "OPEN"
                }
            }
        }
    },
    "guards": {
        "canOpenCashRegister": {
            "description": "Check if no cash register is already open for this tenant"
        },
        "canCloseCashRegister": {
            "description": "Check if cash register has been reconciled"
        },
        "noOpenOrders": {
            "description": "Verify no open orders exist before closing"
        },
        "hasSufficientBalance": {
            "description": "Verify balance is sufficient for drop amount"
        }
    },
    "effects": {
        "OPEN": [
            "recordOpeningBalance",
            "logCashRegisterOpened"
        ],
        "CLOSE": [
            "recordClosingBalance",
            "logCashRegisterClosed"
        ],
        "DROP": [
            "deductFromBalance",
            "logCashDrop"
        ],
        "ADD": [
            "addToBalance",
            "logCashAdd"
        ],
        "SALE": [
            "addSaleToTotal"
        ]
    }
}