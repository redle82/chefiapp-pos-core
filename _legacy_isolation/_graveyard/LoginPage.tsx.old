import React, { useState, useEffect } from 'react';
import { useNavigate, useSearchParams } from 'react-router-dom';
import { supabase } from '../core/supabase';
import { appUrl } from '../utils/url';
import { InlineAlert } from '../ui/design-system';
import { Button } from '../ui/design-system/Button';
import { Card } from '../ui/design-system/Card';
import { Input } from '../ui/design-system/Input';
import { GlobalFooter } from '../components/GlobalFooter';
import { OSSignature } from '../ui/design-system/sovereign/OSSignature';
import { OSFrame } from '../ui/design-system/sovereign/OSFrame';
import { OSCopy } from '../ui/design-system/sovereign/OSCopy';

export const LoginPage = () => {
    const navigate = useNavigate();
    const [searchParams] = useSearchParams();
    const [email, setEmail] = useState('');
    const [password, setPassword] = useState('');
    const [loading, setLoading] = useState(false);
    // Auto-open technical login in local dev for speed
    const isLocal = window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1';
    const [showTechnical, setShowTechnical] = useState(isLocal);
    const [error, setError] = useState<string | null>(null);

    const nextPath = searchParams.get('next') || '/dashboard';
    const justBorn = searchParams.get('born');

    useEffect(() => {
        const autoEmail = searchParams.get('email');
        if (autoEmail) setEmail(autoEmail);

        // MODE HANDLER: Capture onboarding intention
        const mode = searchParams.get('mode');
        if (mode === 'migration') {
            console.log('[LoginPage] Setting onboarding mode to: MIGRATION');
            localStorage.setItem('chefiapp_onboarding_mode', 'migration');
        } else {
            // Se não tem modo explícito, limpamos para não "contaminar"
            // EXCETO se já estiver no meio do processo (assumimos que o start define iniciais)
            // Mas para entrada limpa via Login, resetamos.
            if (!localStorage.getItem('chefiapp_restaurant_id')) {
                localStorage.removeItem('chefiapp_onboarding_mode');
            }
        }
    }, [searchParams]);

    const handleOAuth = async (provider: 'google' | 'apple') => {
        try {
            setLoading(true);
            setError(null);

            // 🔒 ARQUITETURA LOCKED: OAuth sempre redireciona para /app
            // FlowGate é a única autoridade que decide o próximo passo (onboarding ou dashboard).
            // Nunca redirecionar para /bootstrap ou /login diretamente.
            // Ver: E2E_SOVEREIGN_NAVIGATION_VALIDATION.md

            const baseUrl = window.location.origin; // e.g., http://localhost:5173
            const redirectUrl = `${baseUrl}/app`;
            console.log('[LoginPage] OAuth redirect URL:', redirectUrl);

            const { data, error: authErr } = await supabase.auth.signInWithOAuth({
                provider,
                options: {
                    redirectTo: redirectUrl,
                    scopes: 'openid email profile', // Scopes mínimos: apenas email, nome e avatar
                    queryParams: {
                        access_type: 'offline',
                        prompt: 'consent',
                    }
                }
            });

            if (authErr) {
                console.error('[LoginPage] OAuth error:', authErr);
                throw authErr;
            }

            // OAuth redirects automatically, so we don't need to handle navigation here
            // If we reach here, something went wrong
            console.log('[LoginPage] OAuth data:', data);
        } catch (err: any) {
            console.error('[LoginPage] OAuth exception:', err);
            setError(err.message || 'Erro ao iniciar autenticação. Verifique se o Google OAuth está configurado no Supabase.');
            setLoading(false);
        }
    };

    const handleTechnicalLogin = async (e: React.FormEvent) => {
        e.preventDefault();
        setLoading(true);
        setError(null);

        try {
            const { data, error: authErr } = await supabase.auth.signInWithPassword({
                email,
                password
            });
            if (authErr) throw authErr;

            if (data.user) {
                const { data: restaurant } = await supabase
                    .from('gm_restaurants')
                    .select('id')
                    .eq('owner_id', data.user.id)
                    .maybeSingle();

                if (!restaurant) {
                    navigate('/onboarding');
                } else {
                    navigate(nextPath === '/onboarding' ? '/' : nextPath);
                }
            }
        } catch (err: any) {
            setError(err.message);
            setLoading(false);
        }
    };

    return (
        <OSFrame
            context="auth"
            className="login-page-frame"
        // OSFrame provides background and layout basis
        >
            <div style={{
                minHeight: '100vh',
                display: 'flex',
                flexDirection: 'column',
                alignItems: 'center',
                justifyContent: 'center',
                color: '#f5f5f7',
                padding: '20px'
            }}>
                <Card elevated padding="lg" style={{ maxWidth: '400px', width: '100%' }}>
                    <div className="text-center mb-8" style={{ display: 'flex', flexDirection: 'column', alignItems: 'center' }}>
                        {/* Sovereign Logo is now handled by OSFrame (Top Left) */}
                        <div style={{ marginBottom: '16px' }}></div>

                        <h1 style={{ fontSize: '24px', fontWeight: 600, marginBottom: '8px' }}>
                            {OSCopy.auth.loginTitle}
                        </h1>
                        <p style={{ opacity: 0.6, fontSize: '14px' }}>
                            {justBorn ? OSCopy.auth.loginJustBorn : OSCopy.auth.loginSubtitle}
                        </p>
                    </div>

                    {error && (
                        <div style={{ marginBottom: '24px' }}>
                            <InlineAlert
                                type="error"
                                message={error}
                                onDismiss={() => setError(null)}
                            />
                        </div>
                    )}

                    <div style={{ display: 'flex', flexDirection: 'column', gap: '16px' }}>
                        <Button
                            variant="secondary"
                            fullWidth
                            onClick={() => handleOAuth('google')}
                            loading={loading}
                        >
                            <span style={{ marginRight: '8px' }}>🌍</span> {OSCopy.auth.googleButton}
                        </Button>
                        <p style={{
                            fontSize: '12px',
                            opacity: 0.6,
                            marginTop: '-8px',
                            textAlign: 'center',
                            lineHeight: '1.4'
                        }}>
                            {OSCopy.auth.privacyNote}
                        </p>
                    </div>

                    {/* Technical Access Toggle - ALWAYS VISIBLE but subtle */}
                    <div style={{ marginTop: '32px', textAlign: 'center' }}>
                        <button
                            type="button"
                            onClick={() => setShowTechnical(!showTechnical)}
                            style={{
                                background: 'none',
                                border: 'none',
                                color: '#64748b',
                                fontSize: '12px',
                                cursor: 'pointer',
                                textDecoration: 'underline',
                                opacity: 0.5
                            }}
                        >
                            {showTechnical ? 'Ocultar Acesso Técnico' : OSCopy.auth.technicalAccess}
                        </button>
                    </div>

                    {showTechnical && (
                        <form onSubmit={handleTechnicalLogin} style={{ marginTop: '24px', display: 'flex', flexDirection: 'column', gap: '16px', borderTop: '1px solid rgba(255,255,255,0.05)', paddingTop: '24px' }}>
                            <Input
                                type="email"
                                value={email}
                                onChange={(e) => setEmail(e.target.value)}
                                placeholder="Email técnico"
                                label="Email"
                                fullWidth
                                required
                            />
                            <Input
                                type="password"
                                value={password}
                                onChange={(e) => setPassword(e.target.value)}
                                placeholder="Senha"
                                label="Senha"
                                fullWidth
                                required
                            />
                            <Button
                                type="submit"
                                variant="primary"
                                fullWidth
                                loading={loading}
                            >
                                Acessar como Técnico
                            </Button>
                        </form>
                    )}

                    <div style={{ textAlign: 'center', marginTop: '32px', opacity: 0.4, fontSize: '13px' }}>
                        {OSCopy.auth.restrictedArea}
                    </div>
                </Card>

                <GlobalFooter />
            </div >
        </OSFrame>
    );
};

