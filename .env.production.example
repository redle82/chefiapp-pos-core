# =============================================================================
# CHEFIAPP POS CORE — Production Environment Variables
# =============================================================================
# Copy this file to .env.production and fill in real values.
# NEVER commit .env.production to git.
# =============================================================================

# --- Database ---
POSTGRES_USER=chefiapp_prod
POSTGRES_PASSWORD=<GENERATE_STRONG_PASSWORD_64_CHARS>
POSTGRES_DB=chefiapp_production
DB_PORT=5432

# --- Stripe ---
STRIPE_SECRET_KEY=sk_live_<YOUR_STRIPE_LIVE_SECRET_KEY>
STRIPE_PUBLISHABLE_KEY=pk_live_<YOUR_STRIPE_LIVE_PUBLISHABLE_KEY>
STRIPE_WEBHOOK_SECRET=whsec_<YOUR_STRIPE_WEBHOOK_SECRET>

# --- Keycloak ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=<GENERATE_STRONG_PASSWORD_32_CHARS>
KC_HOSTNAME=auth.chefiapp.com
KC_TLS_CERT_PATH=/etc/letsencrypt/live/auth.chefiapp.com/fullchain.pem
KC_TLS_KEY_PATH=/etc/letsencrypt/live/auth.chefiapp.com/privkey.pem

# --- Frontend ---
VITE_CORE_URL=https://api.chefiapp.com/rest
VITE_CORE_ANON_KEY=<GENERATE_JWT_SECRET_MIN_32_CHARS>

# --- PostgREST ---
PGRST_JWT_SECRET=<SAME_AS_VITE_CORE_ANON_KEY>

# --- Sentry (optional) ---
SENTRY_AUTH_TOKEN=
SENTRY_DSN=

# --- Vercel (optional, for frontend CDN) ---
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
