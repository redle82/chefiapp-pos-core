etIsVerifying] = useState(false);\r\n\r\n  const isLinkMethod = method === 'link';\r\n  // Default descriptions based on method\r\n  const displayDescription = isLinkMethod\r\n    ? \"We've sent an email to {email}. Please check your email to confirm your account before signing in. The confirmation link expires in 10 minutes.\"\r\n    : \"We've sent a verification code to your inbox at {email}. Enter it below to proceed.\";\r\n\r\n  // Countdown timer effect\r\n  useEffect(() => {\r\n    if (resendDisabled && resendCountdown > 0) {\r\n      const timer = setInterval(() => {\r\n        setResendCountdown((prev) => {\r\n          if (prev <= 1) {\r\n            setResendDisabled(false);\r\n            return 0;\r\n          }\r\n          return prev - 1;\r\n        });\r\n      }, 1000);\r\n\r\n      return () => clearInterval(timer);\r\n    }\r\n  }, [resendDisabled, resendCountdown]);\r\n\r\n  const handleResend = async () => {\r\n    setResendDisabled(true);\r\n    setResendCountdown(60);\r\n    setIsSending(true);\r\n\r\n    try {\r\n      await resendVerificationEmail(email);\r\n    } catch {\r\n      // If resend fails, re-enable the button immediately\r\n      setResendDisabled(false);\r\n      setResendCountdown(0);\r\n    } finally {\r\n      setIsSending(false);\r\n    }\r\n  };\r\n\r\n  const handleSubmit = async () => {\r\n    if (!onVerifyCode || verificationCode.length !== 6) {\r\n      return;\r\n    }\r\n\r\n    setIsVerifying(true);\r\n\r\n    try {\r\n      await onVerifyCode(verificationCode);\r\n    } finally {\r\n      setIsVerifying(false);\r\n      setVerificationCode('');\r\n    }\r\n  };\r\n\r\n  return (\r\n    <VerificationStepWrapper>\r\n      {/* Description with email (only for link method) */}\r\n      {isLinkMethod && (\r\n        <VerificationStepDescriptionContainer>\r\n          <VerificationStepDescriptionTitle>Verify Your Email</VerificationStepDescriptionTitle>\r\n          <VerificationStepDescription>\r\n            {displayDescription.split('{email}').map((part, index, array) => (\r\n              <span key={index}>\r\n                {part}\r\n                {index < array.length - 1 && <VerificationEmail>{email}</VerificationEmail>}\r\n              </span>\r\n            ))}\r\n          </VerificationStepDescription>\r\n        </VerificationStepDescriptionContainer>\r\n      )}\r\n\r\n      {/* Description with email + code input (only for code method) */}\r\n      {!isLinkMethod && (\r\n        <VerificationStepCodeContainer>\r\n          <VerificationStepCodeInputWrapper>\r\n            <VerificationStepDescription>\r\n              {displayDescription.split('{email}').map((part, index, array) => (\r\n                <span key={index}>\r\n                  {part}\r\n                  {index < array.length - 1 && <VerificationEmail>{email}</VerificationEmail>}\r\n                </span>\r\n              ))}\r\n            </VerificationStepDescription>\r\n            <AuthVerificationCodeInput\r\n              value={verificationCode}\r\n              onChange={setVerificationCode}\r\n              disabled={isVerifying}\r\n            />\r\n          </VerificationStepCodeInputWrapper>\r\n\r\n          <AuthSubmitButton\r\n            type=\"button\"\r\n            isLoading={isVerifying}\r\n            disabled={isVerifying || verificationCode.length !== 6}\r\n            onClick={() => {\r\n              void handleSubmit();\r\n            }}\r\n          >\r\n            {isVerifying ? 'Verifying...' : 'Continue'}\r\n          </AuthSubmitButton>\r\n        </VerificationStepCodeContainer>\r\n      )}\r\n\r\n      {/* Resend Button */}\r\n      <VerificationStepResendContainer>\r\n        Didn&apos;t receive the email?{' '}\r\n        <VerificationStepResendButton\r\n          onClick={() => {\r\n            void handleResend();\r\n          }}\r\n          disabled={resendDisabled || isSending}\r\n        >\r\n          {isSending\r\n            ? 'Sending...'\r\n            : resendDisabled\r\n              ? `Retry in (${resendCountdown}s)`\r\n              : 'Click to resend'}\r\n        </VerificationStepResendButton>\r\n      </VerificationStepResendContainer>\r\n    </VerificationStepWrapper>\r\n  );\r\n}\r\n","import { useState, useEffect, useCallback } from 'react';\r\nimport { AuthVerificationCodeInput } from './AuthVerificationCodeInput';\r\nimport { AuthSubmitButton } from './AuthSubmitButton';\r\nimport type { EmailVerificationMethod } from '../../types';\r\nimport {\r\n  VerificationStepWrapper,\r\n  VerificationStepDescriptionContainer,\r\n  VerificationStepDescriptionTitle,\r\n  VerificationStepDescription,\r\n  VerificationEmail,\r\n  VerificationStepCodeContainer,\r\n  VerificationStepCodeInputWrapper,\r\n  VerificationStepResendContainer,\r\n  VerificationStepResendButton,\r\n} from '../forms/styled';\r\n\r\ninterface AuthResetPasswordVerificationStepProps {\r\n  email: string;\r\n  method: EmailVerificationMethod;\r\n  onVerifyCode?: (code: string) => Promise<void>;\r\n  onResendEmail: () => Promise<void>;\r\n}\r\n\r\n/**\r\n * Reset password verification step component\r\n *\r\n * Handles the verification flow for password reset:\r\n * - Shows appropriate UI based on method (code input or link message)\r\n * - Manages countdown timer for resend functionality\r\n * - Handles code verification for code method\r\n */\r\nexport function AuthResetPasswordVerificationStep({\r\n  email,\r\n  method,\r\n  onVerifyCode,\r\n  onResendEmail,\r\n}: AuthResetPasswordVerificationStepProps) {\r\n  const [resendDisabled, setResendDisabled] = useState(true);\r\n  const [resendCountdown, setResendCountdown] = useState(60);\r\n  const [isSending, setIsSending] = useState(false);\r\n  const [verificationCode, setVerificationCode] = useState('');\r\n  const [isVerifying, setIsVerifying] = useState(false);\r\n\r\n  const isLinkMethod = method === 'link';\r\n  const displayDescription = isLinkMethod\r\n    ? 'We have sent an email to {email}. Please check your email to reset your password. The link expires in 10 minutes.'\r\n    : \"We've sent a reset password code to your inbox at {email}. Enter it below to proceed.\";\r\n\r\n  // Countdown timer effect\r\n  useEffect(() => {\r\n    if (resendCountdown > 0) {\r\n      const timer = setInterval(() => {\r\n        setResendCountdown((prev) => {\r\n          if (prev <= 1) {\r\n            setResendDisabled(false);\r\n            return 0;\r\n          }\r\n          return prev - 1;\r\n        });\r\n      }, 1000);\r\n\r\n      return () => clearInterval(timer);\r\n    }\r\n  }, [resendCountdown]);\r\n\r\n  const handleResend = useCallback(async () => {\r\n    setResendDisabled(true);\r\n    setResendCountdown(60);\r\n    setIsSending(true);\r\n\r\n    try {\r\n      await onResendEmail();\r\n    } catch {\r\n      // If resend fails, re-enable the button immediately\r\n      setResendDisabled(false);\r\n      setResendCountdown(0);\r\n    } finally {\r\n      setIsSending(false);\r\n    }\r\n  }, [onResendEmail]);\r\n\r\n  const handleSubmit = async () => {\r\n    if (!onVerifyCode || verificationCode.length !== 6) {\r\n      return;\r\n    }\r\n\r\n    setIsVerifying(true);\r\n\r\n    try {\r\n      await onVerifyCode(verificationCode);\r\n    } finally {\r\n      setIsVerifying(false);\r\n      setVerificationCode('');\r\n    }\r\n  };\r\n\r\n  return (\r\n    <VerificationStepWrapper>\r\n      {/* Description with email (only for link method) */}\r\n      {isLinkMethod && (\r\n        <VerificationStepDescriptionContainer>\r\n          <VerificationStepDescriptionTitle>Check Your Email</VerificationStepDescriptionTitle>\r\n          <VerificationStepDescription>\r\n            {displayDescription.split('{email}').map((part, index, array) => (\r\n              <span key={index}>\r\n                {part}\r\n                {index < array.length - 1 && <VerificationEmail>{email}</VerificationEmail>}\r\n              </span>\r\n            ))}\r\n          </VerificationStepDescription>\r\n        </VerificationStepDescriptionContainer>\r\n      )}\r\n\r\n      {/* Code Input (only for code method) */}\r\n      {!isLinkMethod && (\r\n        <VerificationStepCodeContainer>\r\n          <VerificationStepCodeInputWrapper>\r\n            <AuthVerificationCodeInput\r\n              value={verificationCode}\r\n              onChange={setVerificationCode}\r\n              disabled={isVerifying}\r\n            />\r\n          </VerificationStepCodeInputWrapper>\r\n\r\n          <AuthSubmitButton\r\n            type=\"button\"\r\n            isLoading={isVerifying}\r\n            disabled={isVerifying || verificationCode.length !== 6}\r\n            onClick={() => {\r\n              void handleSubmit();\r\n            }}\r\n          >\r\n            {isVerifying ? 'Verifying...' : 'Continue'}\r\n          </AuthSubmitButton>\r\n        </VerificationStepCodeContainer>\r\n      )}\r\n\r\n      {/* Resend Button */}\r\n      <VerificationStepResendContainer>\r\n        Didn&apos;t receive the email?{' '}\r\n        <VerificationStepResendButton\r\n          onClick={() => {\r\n            void handleResend();\r\n          }}\r\n          disabled={resendDisabled || isSending}\r\n        >\r\n          {isSending\r\n            ? 'Sending...'\r\n            : resendDisabled\r\n              ? `Retry in (${resendCountdown}s)`\r\n              : 'Click to resend'}\r\n        </VerificationStepResendButton>\r\n      </VerificationStepResendContainer>\r\n    </VerificationStepWrapper>\r\n  );\r\n}\r\n"]}