ng(false);\r\n      return;\r\n    }\r\n\r\n    try {\r\n      const result = await resetPassword(token, newPassword);\r\n\r\n      if (result?.message) {\r\n        setSuccess(true);\r\n      } else {\r\n        const errorMessage = 'Failed to reset password';\r\n        setError(errorMessage);\r\n        if (onError) {\r\n          onError(new Error(errorMessage));\r\n        }\r\n      }\r\n    } catch (err: unknown) {\r\n      const errorMessage = err instanceof Error ? err.message : 'Failed to reset password';\r\n      setError(errorMessage);\r\n      if (onError) {\r\n        onError(new Error(errorMessage));\r\n      }\r\n    } finally {\r\n      setLoading(false);\r\n    }\r\n  }\r\n\r\n  // If email auth config not loaded yet\r\n  if (!authConfig) {\r\n    return null;\r\n  }\r\n\r\n  // If no token, show error\r\n  if (!token) {\r\n    return (\r\n      <AuthContainer>\r\n        <AuthHeader title=\"Invalid Reset Link\" subtitle=\"\" />\r\n        <div\r\n          style={{\r\n            padding: '1.5rem',\r\n            backgroundColor: '#FEE2E2',\r\n            borderRadius: '0.5rem',\r\n            border: '1px solid #DC2626',\r\n          }}\r\n        >\r\n          <p\r\n            style={{\r\n              fontSize: '0.875rem',\r\n              color: '#DC2626',\r\n              margin: 0,\r\n              fontFamily: 'var(--if-font-family)',\r\n            }}\r\n          >\r\n            The password reset link is missing or invalid. Please request a new password reset link.\r\n          </p>\r\n        </div>\r\n      </AuthContainer>\r\n    );\r\n  }\r\n\r\n  // If success, show completion message\r\n  if (success) {\r\n    return (\r\n      <AuthContainer>\r\n        <div\r\n          style={{ display: 'flex', flexDirection: 'column', alignItems: 'center', gap: '1rem' }}\r\n        >\r\n          <div\r\n            style={{\r\n              width: '4rem',\r\n              height: '4rem',\r\n              borderRadius: '50%',\r\n              backgroundColor: '#D1FAE5',\r\n              display: 'flex',\r\n              alignItems: 'center',\r\n              justifyContent: 'center',\r\n            }}\r\n          >\r\n            <svg\r\n              style={{ width: '2rem', height: '2rem', color: '#059669' }}\r\n              fill=\"none\"\r\n              strokeLinecap=\"round\"\r\n              strokeLinejoin=\"round\"\r\n              strokeWidth=\"2\"\r\n              viewBox=\"0 0 24 24\"\r\n              stroke=\"currentColor\"\r\n            >\r\n              <path d=\"M5 13l4 4L19 7\" />\r\n            </svg>\r\n          </div>\r\n          <h2\r\n            style={{\r\n              fontSize: '1.5rem',\r\n              fontWeight: 600,\r\n              color: '#000',\r\n              margin: 0,\r\n              textAlign: 'center',\r\n              fontFamily: 'var(--if-font-family)',\r\n            }}\r\n          >\r\n            Password Reset Successfully\r\n          </h2>\r\n          <p\r\n            style={{\r\n              fontSize: '0.875rem',\r\n              color: '#828282',\r\n              textAlign: 'center',\r\n              margin: 0,\r\n              fontFamily: 'var(--if-font-family)',\r\n            }}\r\n          >\r\n            Your password has been reset successfully. You can now close this page and return to the\r\n            login page in your original tab.\r\n          </p>\r\n        </div>\r\n      </AuthContainer>\r\n    );\r\n  }\r\n\r\n  // Show reset password form\r\n  return (\r\n    <ResetPasswordForm\r\n      newPassword={newPassword}\r\n      confirmPassword={confirmPassword}\r\n      onNewPasswordChange={setNewPassword}\r\n      onConfirmPasswordChange={setConfirmPassword}\r\n      onSubmit={(e) => void handleSubmit(e)}\r\n      error={error}\r\n      loading={loading}\r\n      success={false}\r\n      authConfig={authConfig}\r\n      {...uiProps}\r\n    />\r\n  );\r\n}\r\n","import { AuthContainer, AuthHeader } from '../atoms';\r\nimport {\r\n  VerifyStatusContainer,\r\n  VerifyStatusSpinner,\r\n  VerifyStatusSuccessContent,\r\n  VerifyStatusSuccessIcon,\r\n  VerifyStatusSuccessIconSvg,\r\n  VerifyStatusTextCenter,\r\n} from './styled';\r\nimport { theme } from '../../styles/theme';\r\n\r\nexport interface VerifyEmailStatusProps {\r\n  status: 'verifying' | 'success' | 'error';\r\n  error?: string;\r\n  verifyingTitle?: string;\r\n  successTitle?: string;\r\n  successMessage?: string;\r\n  errorTitle?: string;\r\n}\r\n\r\n/**\r\n * Email verification status display component (UI only, no business logic).\r\n */\r\nexport function VerifyEmailStatus({\r\n  status,\r\n  error,\r\n  verifyingTitle = 'Verifying your email...',\r\n  successTitle = 'Email Verified!',\r\n  successMessage = 'Your email has been verified successfully. You can close this page and sign in to your app.',\r\n  errorTitle = 'Verification Failed',\r\n}: VerifyEmailStatusProps) {\r\n  if (status === 'verifying') {\r\n    return (\r\n      <AuthContainer>\r\n        <VerifyStatusContainer>\r\n          <AuthHeader title={verifyingTitle} />\r\n          <VerifyStatusSpinner />\r\n        </VerifyStatusContainer>\r\n      </AuthContainer>\r\n    );\r\n  }\r\n\r\n  if (status === 'error') {\r\n    return (\r\n      <AuthContainer>\r\n        <VerifyStatusContainer $stretch>\r\n          <AuthHeader\r\n            title={errorTitle}\r\n            subtitle={`${error || 'The verification link is invalid or has expired.'} Please try again or contact support if the problem persists. You can close this page and return to your app.`}\r\n          />\r\n        </VerifyStatusContainer>\r\n      </AuthContainer>\r\n    );\r\n  }\r\n\r\n  // Success state\r\n  return (\r\n    <AuthContainer>\r\n      <VerifyStatusContainer $stretch>\r\n        <VerifyStatusSuccessContent>\r\n          <VerifyStatusSuccessIcon>\r\n            <VerifyStatusSuccessIconSvg>\r\n              <svg\r\n                fill=\"none\"\r\n                strokeLinecap=\"round\"\r\n                strokeLinejoin=\"round\"\r\n                strokeWidth=\"2\"\r\n                viewBox=\"0 0 24 24\"\r\n                stroke=\"currentColor\"\r\n              >\r\n                <path d=\"M5 13l4 4L19 7\" />\r\n              </svg>\r\n            </VerifyStatusSuccessIconSvg>\r\n          </VerifyStatusSuccessIcon>\r\n          <VerifyStatusTextCenter style={{ fontSize: '1.5rem', fontWeight: 600 }}>\r\n            {successTitle}\r\n          </VerifyStatusTextCenter>\r\n          <VerifyStatusTextCenter style={{ color: theme.colors.textSecondary }}>\r\n            {successMessage}\r\n          </VerifyStatusTextCenter>\r\n        </VerifyStatusSuccessContent>\r\n      </VerifyStatusContainer>\r\n    </AuthContainer>\r\n  );\r\n}\r\n","import { useEffect, useState } from 'react';\r\nimport { useInsforge } from '../provider/InsforgeProvider';\r\nimport { VerifyEmailStatus } from './forms/VerifyEmailStatus';\r\nimport { VerifyEmailResponse } from '@insforge/shared-schemas';\r\n\r\nexport interface VerifyEmailProps {\r\n  /** Verification token (from URL query params) */\r\n  token: string;\r\n  /** Text customization */\r\n  verifyingTitle?: string;\r\n  successTitle?: string;\r\n  successMessage?: string;\r\n  errorTitle?: string;\r\n  /** Callback when verification is successful */\r\n  onSuccess?: (data: VerifyEmailResponse) => void;\r\n  /** Callback when verification fails */\r\n  onError?: (error: Error) => void;\r\n}\r\n\r\n/**\r\n * Pre-built email verification component with full business logic.\r\n *\r\n * Automatically verifies the email when mounted using the provided token.\r\n *\r\n * @component\r\n * @example\r\n * ```tsx\r\n * const token = new URLSearchParams(window.location.search).get('token');\r\n *\r\n * <VerifyEmail\r\n *   token={token || ''}\r\n *   onSuccess={(data) => {\r\n *     console.log('Email verified!', data);\r\n *     // Optionally navigate or close window\r\n *   }}\r\n *   onError={(error) => console.error('Verification failed:', error)}\r\n * />\r\n * ```\r\n */\r\nexport function VerifyEmail({ token, onSuccess, onError, ...uiProps }: VerifyEmailProps) {\r\n  const { verifyEmail } = useInsforge();\r\n  const [status, setStatus] = useState<'verifying' | 'success' | 'error'>('verifying');\r\n  const [error, setError] = useState('');\r\n\r\n  useEffect(() => {\r\n    const verifyEmailFn = async () => {\r\n      if (!token) {\r\n        const errorMessage = 'Invalid verification link. Missing required token.';\r\n        setError(errorMessage);\r\n        setStatus('error');\r\n        if (onError) {\r\n          onError(new Error(errorMessage));\r\n        }\r\n        return;\r\n      }\r\n\r\n      try {\r\n        const result = await verifyEmail(token);\r\n\r\n        if ('error' in result) {\r\n          const errorMessage = result.error || 'Email verification failed';\r\n          setError(errorMessage);\r\n          setStatus('error');\r\n          if (onError) {\r\n            onError(new Error(errorMessage));\r\n          }\r\n          return;\r\n        }\r\n\r\n        setStatus('success');\r\n        if (onSuccess) {\r\n          onSuccess(result);\r\n        }\r\n      } catch (err: unknown) {\r\n        const errorMessage = err instanceof Error ? err.message : 'Email verification failed';\r\n        setError(errorMessage);\r\n        setStatus('error');\r\n        if (onError) {\r\n          onError(new Error(errorMessage));\r\n        }\r\n      }\r\n    };\r\n\r\n    void verifyEmailFn();\r\n  }, [token, verifyEmail, onSuccess, onError]);\r\n\r\n  return <VerifyEmailStatus status={status} error={error} {...uiProps} />;\r\n}\r\n","import { cloneElement, isValidElement } from 'react';\r\nimport { useInsforge } from '../provider/InsforgeProvider';\r\n\r\nexport interface SignOutButtonProps {\r\n  children?: React.ReactNode;\r\n  className?: string;\r\n  afterSignOutUrl?: string;\r\n}\r\n\r\n/**\r\n * SignOutButton Component\r\n *\r\n * A simple unstyled butto