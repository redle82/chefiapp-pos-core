st VisuallyHidden = styled.span`\r\n  position: absolute;\r\n  width: 1px;\r\n  height: 1px;\r\n  padding: 0;\r\n  margin: -1px;\r\n  overflow: hidden;\r\n  clip: rect(0, 0, 0, 0);\r\n  white-space: nowrap;\r\n  border-width: 0;\r\n`;\r\n","import { useState, useEffect } from 'react';\r\nimport { AuthVerificationCodeInput } from './AuthVerificationCodeInput';\r\nimport { AuthSubmitButton } from './AuthSubmitButton';\r\nimport { useInsforge } from '../../provider/InsforgeProvider';\r\nimport type { EmailVerificationMethod } from '../../types';\r\nimport {\r\n  VerificationStepWrapper,\r\n  VerificationStepDescriptionContainer,\r\n  VerificationStepDescriptionTitle,\r\n  VerificationStepDescription,\r\n  VerificationEmail,\r\n  VerificationStepCodeContainer,\r\n  VerificationStepCodeInputWrapper,\r\n  VerificationStepResendContainer,\r\n  VerificationStepResendButton,\r\n} from '../forms/styled';\r\n\r\ninterface AuthEmailVerificationStepProps {\r\n  email: string;\r\n  method: EmailVerificationMethod;\r\n  onVerifyCode?: (code: string) => Promise<void>;\r\n  emailSent?: boolean;\r\n}\r\n\r\n/**\r\n * Email verification step component (pure UI, no container)\r\n *\r\n * Designed to be embedded within a form container.\r\n * Handles the email verification flow:\r\n * - Automatically sends verification email on mount\r\n * - Shows countdown timer for resend functionality\r\n * - Manages rate limiting for resend attempts\r\n * - Supports both code and link verification methods\r\n *\r\n * @param method - 'code' for OTP input, 'link' for magic link (default: 'code')\r\n */\r\nexport function AuthEmailVerificationStep({\r\n  email,\r\n  method,\r\n  onVerifyCode,\r\n  emailSent = false,\r\n}: AuthEmailVerificationStepProps) {\r\n  const { resendVerificationEmail } = useInsforge();\r\n  const [resendDisabled, setResendDisabled] = useState(emailSent ? true : false);\r\n  const [resendCountdown, setResendCountdown] = useState(emailSent ? 60 : 0);\r\n  const [isSending, setIsSending] = useState(false);\r\n  const [verificationCode, setVerificationCode] = useState('');\r\n  const [isVerifying, setIsVerifying] = useState(false);\r\n\r\n  const isLinkMethod = method === 'link';\r\n  // Default descriptions based on method\r\n  const displayDescription = isLinkMethod\r\n    ? \"We've sent an email to {email}. Please check your email to confirm your account before signing in. The confirmation link expires in 10 minutes.\"\r\n    : \"We've sent a verification code to your inbox at {email}. Enter it below to proceed.\";\r\n\r\n  // Countdown timer effect\r\n  useEffect(() => {\r\n    if (resendDisabled && resendCountdown > 0) {\r\n      const timer = setInterval(() => {\r\n        setResendCountdown((prev) => {\r\n          if (prev <= 1) {\r\n            setResendDisabled(false);\r\n            return 0;\r\n          }\r\n          return prev - 1;\r\n        });\r\n      }, 1000);\r\n\r\n      return () => clearInterval(timer);\r\n    }\r\n  }, [resendDisabled, resendCountdown]);\r\n\r\n  const handleResend = async () => {\r\n    setResendDisabled(true);\r\n    setResendCountdown(60);\r\n    setIsSending(true);\r\n\r\n    try {\r\n      await resendVerificationEmail(email);\r\n    } catch {\r\n      // If resend fails, re-enable the button immediately\r\n      setResendDisabled(false);\r\n      setResendCountdown(0);\r\n    } finally {\r\n      setIsSending(false);\r\n    }\r\n  };\r\n\r\n  const handleSubmit = async () => {\r\n    if (!onVerifyCode || verificationCode.length !== 6) {\r\n      return;\r\n    }\r\n\r\n    setIsVerifying(true);\r\n\r\n    try {\r\n      await onVerifyCode(verificationCode);\r\n    } finally {\r\n      setIsVerifying(false);\r\n      setVerificationCode('');\r\n    }\r\n  };\r\n\r\n  return (\r\n    <VerificationStepWrapper>\r\n      {/* Description with email (only for link method) */}\r\n      {isLinkMethod && (\r\n        <VerificationStepDescriptionContainer>\r\n          <VerificationStepDescriptionTitle>Ve