leFieldsContainer>\r\n            {/* Email - always read-only */}\r\n            <ProfileField>\r\n              <ProfileFieldLabel>email</ProfileFieldLabel>\r\n              <ProfileFieldValue>{user.email}</ProfileFieldValue>\r\n            </ProfileField>\r\n\r\n            {/* Name - editable */}\r\n            <ProfileField>\r\n              <ProfileFieldLabel>name</ProfileFieldLabel>\r\n              {isEditing ? (\r\n                <ProfileFieldInput\r\n                  type=\"text\"\r\n                  value={name}\r\n                  onChange={(e) => setName(e.target.value)}\r\n                  disabled={isSaving}\r\n                  placeholder=\"Enter your name\"\r\n                />\r\n              ) : (\r\n                <ProfileFieldValue>{user.profile?.name || '-'}</ProfileFieldValue>\r\n              )}\r\n            </ProfileField>\r\n          </ProfileFieldsContainer>\r\n        </ProfileModalBody>\r\n\r\n        <ProfileModalFooter>\r\n          {isEditing ? (\r\n            <>\r\n              <ProfileButton onClick={handleCancel} disabled={isSaving}>\r\n                Cancel\r\n              </ProfileButton>\r\n              <ProfileButton $primary onClick={() => void handleSave()} disabled={isSaving}>\r\n                {isSaving && <ProfileSpinner />}\r\n                {isSaving ? 'Saving...' : 'Save'}\r\n              </ProfileButton>\r\n            </>\r\n          ) : (\r\n            <ProfileButton $primary onClick={() => setIsEditing(true)}>\r\n              Edit Profile\r\n            </ProfileButton>\r\n          )}\r\n        </ProfileModalFooter>\r\n      </ProfileModalContainer>\r\n    </ProfileModalOverlay>\r\n  );\r\n\r\n  // Use portal to render modal outside of any containing block (e.g., elements with backdrop-filter)\r\n  // This ensures position: fixed works correctly relative to the viewport\r\n  return createPortal(modalContent, document.body);\r\n}\r\n","import { useState, useRef, useEffect } from 'react';\r\ni