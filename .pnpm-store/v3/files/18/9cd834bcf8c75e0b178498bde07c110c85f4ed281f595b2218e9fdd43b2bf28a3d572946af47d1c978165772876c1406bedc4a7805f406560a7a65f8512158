 ```tsx\r\n * <AuthFormField\r\n *   id=\"email\"\r\n *   type=\"email\"\r\n *   label=\"Email Address\"\r\n * />\r\n * ```\r\n *\r\n * @param {string} label - Label text\r\n * @param {string} id - Input element ID\r\n */\r\nexport function AuthFormField({ label, id, ...props }: AuthFormFieldProps) {\r\n  return (\r\n    <FormFieldWrapper>\r\n      <FormFieldLabel htmlFor={id}>{label}</FormFieldLabel>\r\n      <FormFieldInput id={id} {...props} />\r\n    </FormFieldWrapper>\r\n  );\r\n}\r\n","import { Check } from 'lucide-react';\r\nimport type { AuthConfig } from '../../types';\r\nimport {\r\n  PasswordStrengthWrapper,\r\n  PasswordStrengthRequirements,\r\n  PasswordStrengthRequirement,\r\n} from './styled';\r\n\r\ninterface PasswordRequirement {\r\n  label: string;\r\n  test: (password: string) => boolean;\r\n}\r\n\r\nexport interface AuthPasswordStrengthIndicatorProps {\r\n  password: string;\r\n  config: AuthConfig;\r\n}\r\n\r\n/**\r\n * Password strength indicator showing requirement checklist.\r\n */\r\nexport function AuthPasswordStrengthIndicator({\r\n  password,\r\n  config,\r\n}: AuthPasswordStrengthIndicatorProps) {\r\n  const requirements = createRequirements(config);\r\n\r\n  return (\r\n    <PasswordStrengthWrapper>\r\n      <PasswordStrengthRequirements>\r\n        {requirements.map((req) => (\r\n          <PasswordStrengthRequirement key={req.label}>\r\n            <div\r\n              style={{\r\n                display: 'flex',\r\n                alignItems: 'center',\r\n                justifyContent: 'center',\r\n                width: '1rem',\r\n                height: '1rem',\r\n                borderRadius: '50%',\r\n                border: '2px solid',\r\n                borderColor: req.test(password) ? 'transparent' : '#9ca3af',\r\n                backgroundColor: req.test(password) ? '#059669' : 'white',\r\n                transition: 'all 0.2s',\r\n              }}\r\n            >\r\n              {req.test(password) && (\r\n                <Check style={{ width: '0.75rem', height: '0.75rem', color: 'white' }} />\r\n              )}\r\n            </div>\r\n            <span>{req.label}</span>\r\n          </PasswordStrengthRequirement>\r\n        ))}\r\n      </PasswordStrengthRequirements>\r\n    </PasswordStrengthWrapper>\r\n  );\r\n}\r\n\r\nfunction createRequirements(config: AuthConfig): PasswordRequirement[] {\r\n  const requirements: PasswordRequirement[] = [];\r\n\r\n  if (config.passwordMinLength) {\r\n    requirements.push({\r\n      label: `At least ${config.passwordMinLength} characters`,\r\n      test: (password) => password.length >= config.passwordMinLength,\r\n    });\r\n  }\r\n\r\n  if (config.requireLowercase) {\r\n    requirements.push({\r\n      label: 'Contains lowercase letter',\r\n      test: (password) => /[a-z]/.test(password),\r\n    });\r\n  }\r\n\r\n  if (config.requireUppercase) {\r\n    requirements.push({\r\n      label: 'Contains uppercase letter',\r\n      test: (password) => /[A-Z]/.test(password),\r\n    });\r\n  }\r\n\r\n  if (config.requireNumber) {\r\n    requirements.push({\r\n      label: 'Contains number',\r\n      test: (password) => /\\d/.test(password),\r\n    });\r\n  }\r\n\r\n  if (config.requireSpecialChar) {\r\n    requirements.push({\r\n      label: 'Contains special character',\r\n      test: (password) => /[!@#$%^&*()_+\\-=[\\]{};':\"\\\\|,.<>/?]/.test(password),\r\n    });\r\n  }\r\n\r\n  return requirements;\r\n}\r\n","/**\r\n * Path utilities for handling navigation in auth flows.\r\n * Ensures proper path resolution when auth pages are served under a base path (e.g., /auth/)\r\n */\r\n\r\n/**\r\n * Resolves an auth route path relative to the current location.\r\n * If the current path is under /auth/, it will preserve that prefix.\r\n * Otherwise, it returns the path as-is.\r\n *\r\n * @param targetPath - The target auth path (e.g., '/sign-in', '/sign-up')\r\n * @returns The resolved path with proper base path handling\r\n *\r\n * @example\r\n * // Current URL: http://localhost:5174/auth/sign-in\r\n * resolveAuthPath('/sign-up') // Returns '/auth/sign-up'\r\n *\r\n * @example\r\n * // Current URL: http://localhost:5174/sign-in\r\n * resolveAuthPath('/sign-up') // Returns '/sign-up'\r\n */\r\nexport function resolveAuthPath(targetPath: string): string {\r\n  if (typeof window === 'undefined') {\r\n    return targetPath;\r\n  }\r\n\r\n  const currentPath = window.location.pathname;\r\n\r\n  // Check if we're currently under /auth/ base path\r\n  if (currentPath.startsWith('/auth/')) {\r\n    // If target already has /auth/ prefix, return as-is\r\n    if (targetPath.startsWith('/auth/')) {\r\n      return targetPath;\r\n    }\r\n    // Add /auth/ prefix to the target path\r\n    return `/auth${targetPath}`;\r\n  }\r\n\r\n  // Not under /auth/, return target path as-is\r\n  return targetPath;\r\n}\r\n\r\n/**\r\n * Resolves an auth route URL with search params preserved.\r\n * Similar to resolveAuthPath but returns a full URL string with query parameters.\r\n *\r\n * @param targetPath - The target auth path (e.g., '/sign-in', '/sign-up')\r\n * @param searchParams - Optional URLSearchParams to append\r\n * @returns The resolved URL as a string\r\n *\r\n * @example\r\n * // Current URL: http://localhost:5174/auth/sign-in?redirect=...\r\n * resolveAuthUrl('/sign-up', searchParams) // Returns '/auth/sign-up?redirect=...'\r\n */\r\nexport function resolveAuthUrl(targetPath: string, searchParams?: URLSearchParams): string {\r\n  const resolvedPath = resolveAuthPath(targetPath);\r\n\r\n  if (!searchParams || searchParams.toString() === '') {\r\n    return resolvedPath;\r\n  }\r\n\r\n  return `${resolvedPath}?${searchParams.toString()}`;\r\n}\r\n","import { useState, useMemo } from 'react';\r\nimport { useSearchParams, useNavigationAdapter } from '../../navigation';\r\nimport { Eye, EyeOff } from 'lucide-react';\r\nimport { AuthPasswordStrengthIndicator } from './AuthPasswordStrengthIndicator';\r\nimport type { InputHTMLAttributes } from 'react';\r\nimport type { AuthConfig } from '../../types';\r\nimport { resolveAuthUrl } from '../../lib/path-utils';\r\nimport {\r\n  PasswordFieldWrapper,\r\n  PasswordFieldLabelRow,\r\n  PasswordFieldLabel,\r\n  PasswordFieldForgotLink,\r\n  PasswordFieldInputWrapper,\r\n  PasswordFieldInput,\r\n  PasswordFieldToggleButton,\r\n} from './styled';\r\n\r\nexport interface AuthPasswordFieldProps extends InputHTMLAttributes<HTMLInputElement> {\r\n  label?: string;\r\n  id: string;\r\n  showStrengthIndicator?: boolean;\r\n  authConfig: AuthConfig;\r\n  forgotPasswordLink?: {\r\n    href: string;\r\n    text?: string;\r\n  };\r\n}\r\n\r\n/**\r\n * Password input field with visibility toggle and optional strength indicator.\r\n */\r\nexport function AuthPasswordField({\r\n  label,\r\n  id,\r\n  showStrengthIndicator = false,\r\n  authConfig,\r\n  forgotPasswordLink,\r\n  value,\r\n  onFocus,\r\n  ...props\r\n}: AuthPasswordFieldProps) {\r\n  const searchParams = useSearchParams();\r\n  const { Link } = useNavigationAdapter();\r\n  const [showPassword, setShowPassword] = useState(false);\r\n  const [showStrength, setShowStrength] = useState(false);\r\n\r\n  // Resolve forgot password link with proper base path handling\r\n  const resolvedForgotPasswordHref = useMemo(\r\n    () => (forgotPasswordLink ? resolveAuthUrl(forgotPasswordLink.href, searchParams) : undefined),\r\n    [forgotPasswordLink, searchParams]\r\n  );\r\n\r\n  const handleFocus = (e: React.FocusEvent<HTMLInputElement>) => {\r\n    if (showStrengthIndicator) {\r\n      setShowStrength(true);\r\n    }\r\n    onFocus?.(e);\r\n  };\r\n\r\n  return (\r\n    <PasswordFieldWrapper>\r\n      {(label || forgotPasswordLink) && (\r\n        <PasswordFieldLabelRow>\r\n          <PasswordFieldLabel htmlFor={id}>{label}</PasswordFieldLabel>\r\n          {forgotPasswordLink && resolvedForgotPasswordHref && (\r\n            <Link href={resolvedForgotPasswordHref} className=\"\">\r\n              <PasswordFieldForgotLink as=\"span\">\r\n                {forgotPasswordLink.text || 'Forget Password?'}\r\n              </PasswordFieldForgotLink>\r\n            </Link>\r\n          )}\r\n        </PasswordFieldLabelRow>\r\n      )}\r\n      <PasswordFieldInputWrapper>\r\n        <PasswordFieldInput\r\n          id={id}\r\n          type={showPassword ? 'text' : 'password'}\r\n          value={value}\r\n          onFocus={handleFocus}\r\n          {...props}\r\n        />\r\n        <PasswordFieldToggleButton\r\n          type=\"button\"\r\n          onClick={() => setShowPassword(!showPassword)}\r\n          aria-label={showPassword ? 'Hide password' : 'Show password'}\r\n        >\r\n          {showPassword ? <EyeOff size={20} /> : <Eye size={20} />}\r\n        </PasswordFieldToggleButton>\r\n      </PasswordFieldInputWrapper>\r\n      {showStrengthIndicator && showStrength && (\r\n        <AuthPasswordStrengthIndicator password={String(value || '')} config={authConfig} />\r\n      )}\r\n    </PasswordFieldWrapper>\r\n  );\r\n}\r\n","import { CircleCheck, Loader2 } from 'lucide-react';\r\nimport type { ReactNode } from 'react';\r\nimport { SubmitButton, SubmitButtonIcon, SubmitButtonSpinner } from './styled';\r\n\r\nexport interface AuthSubmitButtonProps {\r\n  children: ReactNode;\r\n  isLoading?: boolean;\r\n  confirmed?: boolean;\r\n  disabled?: boolean;\r\n  type?: 'button' | 'submit';\r\n  onClick?: () => void;\r\n}\r\n\r\n/**\r\n * Primary button for authentication forms with loading and confirmed states.\r\n *\r\n * Supports two modes:\r\n * - **Form submit** (default): type=\"submit\" - triggers form's onSubmit handler\r\n * - **Action button**: type=\"button\" + onClick - executes custom logic without form submission\r\n *\r\n * @component\r\n * @example\r\n * ```tsx\r\n * // Form submit button (default)\r\n * <AuthSubmitButton isLoading={loading}>\r\n *   Sign In\r\n * </AuthSubmitButton>\r\n *\r\n * // Action button with click handler\r\n * <AuthSubmitButton type=\"button\" onClick={handleClick} isLoading={loading}>\r\n *   Verify Code\r\n * </AuthSubmitButton>\r\n * ```\r\n */\r\nexport function AuthSubmitButton({\r\n  children,\r\n  isLoading = false,\r\n  confirmed = false,\r\n  disabled = false,\r\n  type = 'submit',\r\n  onClick,\r\n}: AuthSubmitButtonProps) {\r\n  return (\r\n    <SubmitButton type={type} disabled={disabled || isLoading || confirmed} onClick={onClick}>\r\n      {isLoading && (\r\n        <SubmitButtonSpinner>\r\n          <Loader2 size={20} />\r\n        </SubmitButtonSpinner>\r\n      )}\r\n      {confirmed && (\r\n        <SubmitButtonIcon>\r\n          <CircleCheck size={20} />\r\n        </SubmitButtonIcon>\r\n      )}\r\n      {children}\r\n    </SubmitButton>\r\n  );\r\n}\r\n","import { useSearchParams, useNavigationAdapter } from '../../navigation';\r\nimport { resolveAuthUrl } from '../../lib/path-utils';\r\nimport { AuthLinkWrapper, AuthLinkText, AuthLinkLink } from './styled';\r\n\r\nexport interface AuthLinkProps {\r\n  text: string;\r\n  linkText: string;\r\n  href: string;\r\n}\r\n\r\n/**\r\n * Call-to-action link component for navigation between auth pages.\r\n *\r\n * @component\r\n * @example\r\n * ```tsx\r\n * <AuthLink\r\n *   text=\"Don't have an account?\"\r\n *   linkText=\"Sign up\"\r\n *   href=\"/sign-up\"\r\n * />\r\n * ```\r\n *\r\n * @param {string} text - Regular text before the link\r\n * @param {string} linkText - Clickable link text\r\n * @param {string} href - Link URL\r\n */\r\nexport function AuthLink({ text, linkText, href }: AuthLinkProps) {\r\n  const searchParams = useSearchParams();\r\n  const { Link } = useNavigationAdapter();\r\n\r\n  // Resolve auth path with proper base path handling and preserve search params\r\n  const finalHref = resolveAuthUrl(href, searchParams);\r\n\r\n  return (\r\n    <AuthLinkWrapper>\r\n      {text && <AuthLinkText>{text}</AuthLinkText>}\r\n      {text && ' '}\r\n      <Link href={finalHref} className=\"\">\r\n        <AuthL