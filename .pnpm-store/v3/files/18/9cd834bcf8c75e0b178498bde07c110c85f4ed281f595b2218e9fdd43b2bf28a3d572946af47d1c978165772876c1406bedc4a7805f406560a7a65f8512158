nction getAllProviderConfigs(): Partial<Record<OAuthProvider, OAuthProviderConfig>> {\r\n  return OAUTH_PROVIDER_CONFIG;\r\n}\r\n","import { Loader2 } from 'lucide-react';\r\nimport { getProviderConfig } from '../../config/oauth-providers';\r\nimport type { OAuthProvidersSchema } from '@insforge/shared-schemas';\r\nimport type { CSSProperties } from 'react';\r\nimport { OAuthButton, OAuthButtonIcon, SubmitButtonSpinner } from './styled';\r\n\r\nexport interface AuthOAuthButtonProps {\r\n  provider: OAuthProvidersSchema;\r\n  onClick: (provider: OAuthProvidersSchema) => void;\r\n  disabled?: boolean;\r\n  loading?: boolean;\r\n  displayMode?: 'full' | 'short' | 'icon';\r\n  style?: CSSProperties;\r\n}\r\n\r\n/**\r\n * OAuth provider button with adaptive display modes.\r\n */\r\nexport function AuthOAuthButton({\r\n  provider,\r\n  onClick,\r\n  disabled,\r\n  loading,\r\n  displayMode = 'full',\r\n  style,\r\n}: AuthOAuthButtonProps) {\r\n  const config = getProviderConfig(provider);\r\n\r\n  if (!config) {\r\n    return null;\r\n  }\r\n\r\n  const getButtonText = () => {\r\n    if (displayMode === 'full') {\r\n      return `Continue with ${config.name}`;\r\n    }\r\n    if (displayMode === 'short') {\r\n      return config.name;\r\n    }\r\n    return '';\r\n  };\r\n\r\n  const variant = displayMode === 'icon' ? 'iconOnly' : displayMode;\r\n\r\n  return (\r\n    <OAuthButton\r\n      type=\"button\"\r\n      onClick={() => onClick(provider)}\r\n      $variant={variant}\r\n      disabled={disabled || loading}\r\n      style={style}\r\n    >\r\n      {loading ? (\r\n        <SubmitButtonSpinner>\r\n          <Loader2 size={18} />\r\n        </SubmitButtonSpinner>\r\n      ) : (\r\n        <OAuthButtonIcon>{config.svg}</OAuthButtonIcon>\r\n      )}\r\n      {!loading && getButtonText() && <span>{getButtonText()}</span>}\r\n    </OAuthButton>\r\n  );\r\n}\r\n","import { AuthOAuthButton } from './AuthOAuthButton';\r\nimport type { OAuthProvidersSchema } from '@insforge/s