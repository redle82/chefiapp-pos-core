});\r\n        if (!response.ok) {\r\n          setImageError(true);\r\n        }\r\n      } catch (error: unknown) {\r\n        if (error instanceof Error) {\r\n          console.error('Error checking image URL:', error.message);\r\n        }\r\n        setImageError(true);\r\n      }\r\n    };\r\n\r\n    void checkImageUrl();\r\n  }, [user?.profile?.avatar_url]);\r\n\r\n  // Detect position and determine menu placement (vertical and horizontal)\r\n  useEffect(() => {\r\n    if (isOpen && dropdownRef.current) {\r\n      const buttonRect = dropdownRef.current.getBoundingClientRect();\r\n      const viewportHeight = window.innerHeight;\r\n      const viewportWidth = window.innerWidth;\r\n\r\n      // Vertical positioning\r\n      const spaceBelow = viewportHeight - buttonRect.bottom;\r\n      const spaceAbove = buttonRect.top;\r\n      const menuHeight = 200; // Estimate\r\n      const shouldOpenUpward = spaceBelow < menuHeight && spaceAbove > spaceBelow;\r\n      setOpenUpward(shouldOpenUpward);\r\n\r\n      // Horizontal positioning\r\n      // We need to wait for next tick to get the menu's actual width\r\n      requestAnimationFrame(() => {\r\n        if (menuRef.current) {\r\n          const menuWidth = menuRef.current.offsetWidth;\r\n          const menuRight = buttonRect.left + menuWidth;\r\n          const viewportPadding = 16; // 16px padding from viewport edge\r\n\r\n          // If menu would overflow right edge of viewport\r\n          if (menuRight > viewportWidth - viewportPadding) {\r\n            // Calculate how much to shift left\r\n            const overflow = menuRight - (viewportWidth - viewportPadding);\r\n            setHorizontalOffset(-overflow);\r\n          } else {\r\n            setHorizontalOffset(0);\r\n          }\r\n        }\r\n      });\r\n    } else {\r\n      // Reset when closed\r\n      setHorizontalOffset(0);\r\n    }\r\n  }, [isOpen]);\r\n\r\n  useEffect(() => {\r\n    function handleClickOutside(event: MouseEvent) {\r\n      if (dropdownRef.current && !dropdownRef.current.contains(event.target as Node)) {\r\n        setIsOpen(false);\r\n      }\r\n    }\r\n\r\n    if (isOpen) {\r\n      document.addEventListener('mousedown', handleClickOutside);\r\n    }\r\n\r\n    return () => {\r\n      document.removeEventListener('mousedown', handleClickOutside);\r\n    };\r\n  }, [isOpen]);\r\n\r\n  if (!user) {\r\n    return null;\r\n  }\r\n\r\n  const initials = user.profile?.name\r\n    ? user.profile.name.charAt(0).toUpperCase()\r\n    : user.email.split('@')[0].slice(0, 2).toUpperCase();\r\n\r\n  return (\r\n    <UserButtonContainer ref={dropdownRef}>\r\n      <UserButtonButton\r\n        $detailed={mode === 'detailed'}\r\n        onClick={() => setIsOpen(!isOpen)}\r\n        aria-expanded={isOpen}\r\n        aria-haspopup=\"true\"\r\n      >\r\n        <UserButtonAvatar>\r\n          {user.profile?.avatar_url && !imageError ? (\r\n            <UserButtonAvatarImage\r\n              src={user.profile.avatar_url}\r\n              alt={user.email}\r\n              onError={() => setImageError(true)}\r\n            />\r\n          ) : (\r\n            <UserButtonAvatarInitials>{initials}</UserButtonAvatarInitials>\r\n          )}\r\n        </UserButtonAvatar>\r\n        {mode === 'detailed' && (\r\n          <UserButtonInfo>\r\n            {user.profile?.name && <UserButtonName>{user.profile.name}</UserButtonName>}\r\n            <UserButtonEmail>{user.email}</UserButtonEmail>\r\n          </UserButtonInfo>\r\n        )}\r\n      </UserButtonButton>\r\n\r\n      {isOpen && (\r\n        <UserButtonMenu ref={menuRef} $openUpward={openUpward} $horizontalOffset={horizontalOffset}>\r\n          {showProfile && (\r\n            <UserButtonMenuItem\r\n              onClick={() => {\r\n                setShowProfileModal(true);\r\n                setIsOpen(false);\r\n              }}\r\n            >\r\n              <UserButtonMenuItemIcon>\r\n                <User />\r\n              </UserButtonMenuItemIcon>\r\n              Profile\r\n            </UserButtonMenuItem>\r\n          )}\r\n          <SignOutButton afterSignOutUrl={afterSignOutUrl}>\r\n            <UserButtonMenuItem $signout onClick={() => setIsOpen(false)}>\r\n              <UserButtonMenuItemIcon>\r\n                <LogOut />\r\n              </UserButtonMenuItemIcon>\r\n              Sign out\r\n            </UserButtonMenuItem>\r\n          </SignOutButton>\r\n        </UserButtonMenu>\r\n      )}\r\n\r\n      {showProfileModal && (\r\n        <UserProfileModal onClose={() => setShowProfileModal(false)} onError={onProfileError} />\r\n      )}\r\n    </UserButtonContainer>\r\n  );\r\n}\r\n","import { useInsforge } from '../provider/InsforgeProvider';\r\nimport { useEffect, useMemo } from 'react';\r\nimport type { ReactNode } from 'react';\r\nimport type { InsforgeUser } from '../types';\r\nimport { resolveAuthPath } from '../lib/path-utils';\r\n\r\nexport interface ProtectProps {\r\n  children: ReactNode;\r\n  fallback?: ReactNode;\r\n  redirectTo?: string;\r\n  condition?: (user: InsforgeUser) => boolean;\r\n  onRedirect?: (url: string) => void;\r\n}\r\n\r\n/**\r\n * Protected route component that redirects unauthenticated users.\r\n *\r\n * @component\r\n * @example\r\n * ```tsx\r\n * // Basic usage\r\n * <Protect redirectTo=\"/sign-in\">\r\n *   <Dashboard />\r\n * </Protect>\r\n *\r\n * // With custom redirect handler (e.g., for Next.js router)\r\n * <Protect\r\n *   redirectTo=\"/sign-in\"\r\n *   onRedirect={(url) => router.push(url)}\r\n * >\r\n *   <AdminPanel />\r\n * </Protect>\r\n *\r\n * // With custom condition (role-based access)\r\n * <Protect\r\n *   redirectTo=\"/unauthorized\"\r\n *   condition={(user) => user.role === 'admin'}\r\n * >\r\n *   <AdminContent />\r\n * </Protect>\r\n * ```\r\n *\r\n * @param {ReactNode} children - Content to protect\r\n * @param {ReactNode} [fallback] - Fallback UI while loading\r\n * @param {string} [redirectTo='/sign-in'] - Redirect URL\r\n * @param {function} [condition] - Custom access condition\r\n * @param {function} [onRedirect] - Custom redirect handler (default: window.location)\r\n */\r\nexport function Protect({\r\n  children,\r\n  fallback,\r\n  redirectTo = '/sign-in',\r\n  condition,\r\n  onRedirect,\r\n}: ProtectProps): ReactNode {\r\n  const { userId, user } = useInsforge();\r\n\r\n  // Resolve redirect path with proper base path handling\r\n  const resolvedRedirectTo = useMemo(() => resolveAuthPath(redirectTo), [redirectTo]);\r\n\r\n  useEffect(() => {\r\n    // undefined = not loaded yet, don't redirect\r\n    // null = loaded and signed out, redirect\r\n    // string = signed in, check condition\r\n    if (userId === null) {\r\n      // Not signed in, redirect\r\n      if (onRedirect) {\r\n        onRedirect(resolvedRedirectTo);\r\n      } else {\r\n        window.location.href = resolvedRedirectTo;\r\n      }\r\n    } else if (userId && condition && user) {\r\n      // Signed in but condition failed, redirect\r\n      if (!condition(user)) {\r\n        if (onRedirect) {\r\n          onRedirect(resolvedRedirectTo);\r\n        } else {\r\n          window.location.href = resolvedRedirectTo;\r\n        }\r\n      }\r\n    }\r\n  }, [userId, resolvedRedirectTo, condition, user, onRedirect]);\r\n\r\n  // Show fallback while loading (undefined = not loaded)\r\n  if (userId === undefined) {\r\n    return fallback || <div className=\"insforge-loading\">Loading...</div>;\r\n  }\r\n\r\n  // Don't render if not signed in (null = signed out)\r\n  if (userId === null) {\r\n    return fallback || null;\r\n  }\r\n\r\n  // Don't render if condition fails\r\n  if (condition && user && !condition(user)) {\r\n    return fallback || null;\r\n  }\r\n\r\n  return <>{children}</>;\r\n}\r\n","import { useInsforge } from '../provider/InsforgeProvider';\r\nimport type { ReactNode } from 'react';\r\n\r\nexport interface ConditionalProps {\r\n  children: ReactNode;\r\n}\r\n\r\n/**\r\n * Conditional component that renders children only when user is signed in.\r\n *\r\n * Uses userId to determine rendering:\r\n * - undefined = not loaded yet (SSR or before hydration) -> render null\r\n * - null = loaded, user signed out -> render null\r\n * - string = loaded, user signed in -> render children\r\n *\r\n * This prevents hydration mismatches in Next.js SSR by ensuring\r\n * consistent rendering between server and client initial render.\r\n *\r\n * @component\r\n * @example\r\n * ```tsx\r\n * <SignedIn>\r\n *   <Dashboard />\r\n * </SignedIn>\r\n * ```\r\n *\r\n * @param {ReactNode} children - React nodes to render when user is authenticated\r\n * @returns {JSX.Element | null} Renders children when signed in, null otherwise\r\n */\r\nexport function SignedIn({ children }: ConditionalProps) {\r\n  const { userId } = useInsforge();\r\n\r\n  // undefined = not loaded yet, render null (prevents hydration mismatch)\r\n  // null = loaded but signed out, render null\r\n  // string = signed in, render children\r\n  if (userId) {\r\n    return <>{children}</>;\r\n  }\r\n\r\n  return null;\r\n}\r\n","import { useInsforge } from '../provider/InsforgeProvider';\r\nimport type { ReactNode } from 'react';\r\n\r\nexport interface ConditionalProps {\r\n  children: ReactNode;\r\n}\r\n\r\n/**\r\n * Conditional component that renders children only when user is signed out.\r\n *\r\n * Uses userId to determine rendering:\r\n * - undefined = not loaded yet (SSR or before hydration) -> render null\r\n * - null = loaded, user signed out -> render children\r\n * - string = loaded, user signed in -> render null\r\n *\r\n * This prevents hydration mismatches in Next.js SSR by ensuring\r\n * consistent rendering between server and client initial render.\r\n *\r\n * @component\r\n * @example\r\n * ```tsx\r\n * <SignedOut>\r\n *   <SignIn />\r\n * </SignedOut>\r\n * ```\r\n *\r\n * @param {ReactNode} children - React nodes to render when user is not authenticated\r\n * @returns {JSX.Element | null} Renders children when signed out, null otherwise\r\n */\r\nexport function SignedOut({ children }: ConditionalProps) {\r\n  const { userId } = useInsforge();\r\n\r\n  // undefined = not loaded yet, render null (prevents hydration mismatch)\r\n  // null = loaded and signed out, render children\r\n  // string = signed in, render null\r\n  if (userId === null) {\r\n    return <>{children}</>;\r\n  }\r\n\r\n  return null;\r\n}\r\n","import { cloneElement, isValidElement } from 'react';\r\nimport { useInsforge } from '../provider/InsforgeProvider';\r\n\r\nexport interface SignInButtonProps {\r\n  children?: React.ReactNode;\r\n  className?: string;\r\n}\r\n\r\n/**\r\n * SignInButton Component\r\n *\r\n * A simple unstyled button that redirects to the hosted sign-in page.\r\n * If children is a valid React element, it will be rendered with the redirect logic attached.\r\n *\r\n * @example\r\n * ```tsx\r\n * <SignInButton />\r\n * ```\r\n *\r\n * @example\r\n * ```tsx\r\n * <SignInButton>\r\n *   <button className=\"your-button\">Login</button>\r\n * </SignInButton>\r\n * ```\r\n */\r\nexport function SignInButton({ children, className }: SignInButtonProps) {\r\n  const { afterSignInUrl, baseUrl } = useInsforge();\r\n\r\n  const handleClick = () => {\r\n    const redirectUrl = new URL(afterSignInUrl, window.location.origin).href;\r\n    const authUrl = new URL('/auth/sign-in', baseUrl);\r\n    authUrl.searchParams.set('redirect', redirectUrl);\r\n    window.location.replace(authUrl.toString());\r\n  };\r\n\r\n  if (children && isValidElement(children)) {\r\n    const originalOnClick = (children.props as { onClick?: (e: React.MouseEvent) => void })\r\n      ?.onClick;\r\n\r\n    return cloneElement(children, {\r\n      onClick: (e: React.MouseEvent) => {\r\n        handleClick();\r\n        if (originalOnClick) {\r\n          originalOnClick(e);\r\n        }\r\n      },\r\n    } as Record<string, unknown>);\r\n  }\r\n\r\n  // Default button\r\n  return (\r\n    <button type=\"button\" className={className} onClick={handleClick}>\r\n      {children || 'Sign in'}\r\n    </button>\r\n  );\r\n}\r\n","import { cloneElement, isValidElement } from 'react';\r\nimport { useInsforge } from '../provider/InsforgeProvider';\r\n\r\nexport interface SignUpButtonProps {\r\n  children?: React.ReactNode;\r\n  className?: string;\r\n}\r\n\r\n/**\r\n * SignUpButton Component\r\n *\r\n * A simple unstyled button that redirects to the hosted sign-up page.\r\n * If children is a valid React element, it will be rendered with the redirect logic attached.\r\n *\r\n * @example\r\n * ```tsx\r\n * <SignUpButton />\r\n * ```\r\n *\r\n * @example\r\n * ```tsx\r\n * <SignUpButton>\r\n *   <button className=\"fancy-button\">Register Now</button>\r\n * </SignUpButton>\r\n * ```\r\n */\r\nexport function SignUpButton({ children, className }: SignUpButtonProps) {\r\n  const { afterSignInUrl, baseUrl } = useInsforge();\r\n\r\n  const handleClick = () => {\r\n    const redirectUrl = new URL(afterSignInUrl, window.location.origin).href;\r\n    const authUrl = new URL('/auth/sign-up', baseUrl);\r\n    authUrl.searchParams.set('redirect', redirectUrl);\r\n    window.location.replace(authUrl.toString());\r\n  };\r\n\r\n  if (children && isValidElement(children)) {\r\n    const originalOnClick = (children.props as { onClick?: (e: React.MouseEvent) => void })\r\n      ?.onClick;\r\n\r\n    return cloneElement(children, {\r\n      onClick: (e: React.MouseEvent) => {\r\n        handleClick();\r\n        if (originalOnClick) {\r\n          originalOnClick(e);\r\n        }\r\n      },\r\n    } as Record<string, unknown>);\r\n  }\r\n\r\n  // Default button\r\n  return (\r\n    <button type=\"button\" className={className} onClick={handleClick}>\r\n      {children || 'Sign up'}\r\n    </button>\r\n  );\r\n}\r\n","import { CreateSessionResponse, CreateUserResponse } from '@insforge/shared-schemas';\r\nimport { useInsforge } from '../provider/InsforgeProvider';\r\n\r\n/**\r\n * Hook to access authentication methods\r\n *\r\n * @returns Object containing:\r\n *   - `signIn`: Function to sign in with email and password\r\n *   - `signUp`: Function to sign up with email and password\r\n *   - `signOut`: Function to sign out the current user\r\n *   - `isLoaded`: Boolean indicating if auth state has been loaded\r\n *   - `isSignedIn`: Boolean indicating if user is currently signed in\r\n *\r\n * @example\r\n * ```tsx\r\n * function LoginForm() {\r\n *   const { signIn, signUp, signOut, isLoaded, isSignedIn } = useAuth();\r\n *\r\n *   async function handleLogin(email: string, password: string) {\r\n *     try {\r\n *       await signIn(email, password);\r\n *       // User is now signed in\r\n *     } catch (error) {\r\n *       console.error('Sign in failed:', error);\r\n *     }\r\n *   }\r\n *\r\n *   if (!isLoaded) return <div>Loading...</div>;\r\n *\r\n *   return (\r\n *     <form onSubmit={(e) => { e.preventDefault(); handleLogin(email, password); }}>\r\n *       {/* form fields *\\/}\r\n *     </form>\r\n *   );\r\n * }\r\n * ```\r\n */\r\nexport function useAuth(): {\r\n  signIn: (\r\n    email: string,\r\n    password: string\r\n  ) => Promise<CreateSessionResponse | { error: string; statusCode?: number; errorCode?: string }>;\r\n  signUp: (\r\n    email: string,\r\n    password: string\r\n  ) => Promise<CreateUserResponse | { error: string; statusCode?: number; errorCode?: string }>;\r\n  signOut: () => Promise<void>;\r\n  isLoaded: boolean;\r\n  isSignedIn: boolean | undefined;\r\n} {\r\n  const { signIn, signUp, signOut, isLoaded, isSignedIn } = useInsforge();\r\n  return { signIn, signUp, signOut, isLoaded, isSignedIn };\r\n}\r\n","import { InsforgeUser } from '@insforge/shared';\r\nimport { useInsforge } from '../provider/InsforgeProvider';\r\n\r\nexport interface useUserReturn {\r\n  user: InsforgeUser | null | undefined;\r\n  isLoaded: boolean;\r\n  updateUser: (data: InsforgeUser['profile']) => Promise<{ error: string } | null>;\r\n  setUser: (user: InsforgeUser | null) => void;\r\n}\r\n\r\n/**\r\n * Hook to access current user data\r\n *\r\n * @returns Object containing:\r\n *   - `user`: Current user object (InsforgeUser | null)\r\n *   - `isLoaded`: Boolean indicating if auth state has been loaded\r\n *   - `updateUser`: Function to update user profile data (returns { error: string } | null)\r\n *   - `setUser`: Internal function to manually set user state\r\n *\r\n * @example\r\n * ```tsx\r\n * function UserProfile() {\r\n *   const { user, isLoaded, updateUser } = useUser();\r\n *\r\n *   if (!isLoaded) return <div>Loading...</div>;\r\n *   if (!user) return <div>Not signed in</div>;\r\n *\r\n *   async function handleUpdate(name: string) {\r\n *     const result = await updateUser({ name });\r\n *     if (result?.error) {\r\n *       console.error(result.error);\r\n *     } else {\r\n *       console.log('User updated successfully');\r\n *     }\r\n *   }\r\n *\r\n *   return (\r\n *     <div>\r\n *       <p>Email: {user.email}</p>\r\n *       {user.name && <p>Name: {user.name}</p>}\r\n *       {user.avatarUrl && <img src={user.avatarUrl} alt=\"Avatar\" />}\r\n *     </div>\r\n *   );\r\n * }\r\n * ```\r\n */\r\nexport function useUser(): useUserReturn {\r\n  const { user, isLoaded, updateUser, setUser } = useInsforge();\r\n  return { user, isLoaded, updateUser, setUser };\r\n}\r\n"]}