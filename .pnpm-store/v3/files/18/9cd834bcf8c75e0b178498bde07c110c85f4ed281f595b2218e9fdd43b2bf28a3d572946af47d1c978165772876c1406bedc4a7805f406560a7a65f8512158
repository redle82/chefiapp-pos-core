 < array.length - 1 && <VerificationEmail>{email}</VerificationEmail>}\r\n              </span>\r\n            ))}\r\n          </VerificationStepDescription>\r\n        </VerificationStepDescriptionContainer>\r\n      )}\r\n\r\n      {/* Code Input (only for code method) */}\r\n      {!isLinkMethod && (\r\n        <VerificationStepCodeContainer>\r\n          <VerificationStepCodeInputWrapper>\r\n            <AuthVerificationCodeInput\r\n              value={verificationCode}\r\n              onChange={setVerificationCode}\r\n              disabled={isVerifying}\r\n            />\r\n          </VerificationStepCodeInputWrapper>\r\n\r\n          <AuthSubmitButton\r\n            type=\"button\"\r\n            isLoading={isVerifying}\r\n            disabled={isVerifying || verificationCode.length !== 6}\r\n            onClick={() => {\r\n              void handleSubmit();\r\n            }}\r\n          >\r\n            {isVerifying ? 'Verifying...' : 'Continue'}\r\n          </AuthSubmitButton>\r\n        </VerificationStepCodeContainer>\r\n      )}\r\n\r\n      {/* Resend Button */}\r\n      <VerificationStepResendContainer>\r\n        Didn&apos;t receive the email?{' '}\r\n        <VerificationStepResendButton\r\n          onClick={() => {\r\n            void handleResend();\r\n          }}\r\n          disabled={resendDisabled || isSending}\r\n        >\r\n          {isSending\r\n            ? 'Sending...'\r\n            : resendDisabled\r\n              ? `Retry in (${resendCountdown}s)`\r\n              : 'Click to resend'}\r\n        </VerificationStepResendButton>\r\n      </VerificationStepResendContainer>\r\n    </VerificationStepWrapper>\r\n  );\r\n}\r\n","import {\r\n  AuthContainer,\r\n  AuthHeader,\r\n  AuthErrorBanner,\r\n  AuthFormField,\r\n  AuthPasswordField,\r\n  AuthSubmitButton,\r\n  AuthLink,\r\n  AuthDivider,\r\n  AuthOAuthProviders,\r\n  AuthEmailVerificationStep,\r\n} from '../atoms';\r\nimport type { OAuthProvidersSchema } from '@insforge/shared-schemas';\r\nimport type { FormEvent } from 'react';\r\nimport type { AuthConfig } from '../../types';\r\nimport { theme } from '../../styles/theme';\r\n\r\nexport interface SignInFormProps {\r\n  email: string;\r\n  password: string;\r\n  onEmailChange: (email: string) => void;\r\n  onPasswordChange: (password: string) => void;\r\n  onSubmit: (e: FormEvent<HTMLFormElement>) => void;\r\n  error?: string;\r\n  loading?: boolean;\r\n  oauthLoading?: OAuthProvidersSchema | null;\r\n  onOAuthClick?: (provider: OAuthProvidersSchema) => void;\r\n  authConfig: AuthConfig;\r\n  title?: string;\r\n  subtitle?: string;\r\n  emailLabel?: string;\r\n  emailPlaceholder?: string;\r\n  passwordLabel?: string;\r\n  passwordPlaceholder?: string;\r\n  forgotPasswordText?: string;\r\n  forgotPasswordUrl?: string;\r\n  submitButtonText?: string;\r\n  loadingButtonText?: string;\r\n  signUpText?: string;\r\n  signUpLinkText?: string;\r\n  signUpUrl?: string;\r\n  dividerText?: string;\r\n  showVerificationStep?: boolean;\r\n  onVerifyCode?: (code: string) => Promise<void>;\r\n}\r\n\r\n/**\r\n * Pre-built sign-in form component (UI only, no business logic).\r\n */\r\nexport function SignInForm({\r\n  email,\r\n  password,\r\n  onEmailChange,\r\n  onPasswordChange,\r\n  onSubmit,\r\n  error,\r\n  loading = false,\r\n  oauthLoading = null,\r\n  onOAuthClick,\r\n  authConfig,\r\n  title = 'Welcome Back',\r\n  subtitle = 'Login to your account',\r\n  emailLabel = 'Email',\r\n  emailPlaceholder = 'example@email.com',\r\n  passwordLabel = 'Password',\r\n  passwordPlaceholder = '••••••',\r\n  forgotPasswordText = 'Forget Password?',\r\n  forgotPasswordUrl = '/forgot-password',\r\n  submitButtonText = 'Sign In',\r\n  loadingButtonText = 'Signing in...',\r\n  signUpText = \"Don't have an account?\",\r\n  signUpLinkText = 'Sign Up Now',\r\n  signUpUrl = '/sign-up',\r\n  dividerText = 'or',\r\n  showVerificationStep = false,\r\n  onVerifyCode,\r\n}: SignInFormProps) {\r\n  return (\r\n    <AuthContainer>\r\n      <AuthHeader title={title} subtitle={subtitle} />\r\n\r\n      <AuthErrorBanner error={error || ''} />\r\n\r\n      {showVerificationStep ? (\r\n        <AuthEmailVerificationStep\r\n          email={email}\r\n          method={authConfig.verifyEmailMethod}\r\n          onVerifyCode={onVerifyCode}\r\n          emailSent={false}\r\n        />\r\n      ) : (\r\n        <form\r\n          onSubmit={onSubmit}\r\n          noValidate\r\n          style={{ display: 'flex', flexDirection: 'column', gap: theme.spacing[6] }}\r\n        >\r\n          <AuthFormField\r\n            id=\"email\"\r\n            type=\"email\"\r\n            label={emailLabel}\r\n            placeholder={emailPlaceholder}\r\n            value={email}\r\n            onChange={(e) => onEmailChange(e.target.value)}\r\n            required\r\n            autoComplete=\"email\"\r\n          />\r\n\r\n          <AuthPasswordField\r\n            id=\"password\"\r\n            label={passwordLabel}\r\n            placeholder={passwordPlaceholder}\r\n            value={password}\r\n            onChange={(e) => onPasswordChange(e.target.value)}\r\n            required\r\n            autoComplete=\"current-password\"\r\n            authConfig={authConfig}\r\n            forgotPasswordLink={\r\n              forgotPasswordUrl\r\n                ? {\r\n                    href: forgotPasswordUrl,\r\n                    text: forgotPasswordText,\r\n                  }\r\n                : undefined\r\n            }\r\n          />\r\n\r\n          <AuthSubmitButton isLoading={loading} disabled={loading || oauthLoading !== null}>\r\n            {loading ? loadingButtonText : submitButtonText}\r\n          </AuthSubmitButton>\r\n        </form>\r\n      )}\r\n\r\n      {!showVerificationStep && (\r\n        <>\r\n          <AuthLink text={signUpText} linkText={signUpLinkText} href={signUpUrl} />\r\n\r\n          {authConfig.oAuthProviders.length > 0 && onOAuthClick && (\r\n            <>\r\n              <AuthDivider text={dividerText} />\r\n              <AuthOAuthProviders\r\n                providers={authConfig.oAuthProviders}\r\n                onClick={onOAuthClick}\r\n                disabled={loading || oauthLoading !== null}\r\n                loading={oauthLoading}\r\n              />\r\n            </>\r\n          )}\r\n        </>\r\n      )}\r\n    </AuthContainer>\r\n  );\r\n}\r\n","/**\r\n * Hosted Auth Helpers\r\n *\r\n * Utilities for detecting hosted auth environment and building legacy auth URLs\r\n * for cross-domain authentication flows.\r\n */\r\n\r\n/**\r\n * Get CSRF token from cookie\r\n *\r\n * Reads the insforge_csrf_token cookie set by the backend after authentication.\r\n * This is needed for OAuth flows where the csrfToken is stored in cookies\r\n * rather than returned in the API response.\r\n *\r\n * @returns The CSRF token value or null if not found\r\n */\r\nexport function getCsrfTokenFromCookie(): string | null {\r\n  if (typeof document === 'undefined') return null;\r\n  const match = document.cookie.match(/(?:^|;\\s*)insforge_csrf_token=([^;]*)/);\r\n  return match ? decodeURIComponent(match[1]) : null;\r\n}\r\n\r\n/**\r\n * Check if current environment is a hosted auth environment\r\n *\r\n * Returns true for:\r\n * - localhost with port 7130 (hosted auth app dev)\r\n * - https://*.insforge.app (hosted auth app production)\r\n *\r\n * @returns true if running in hosted auth environment\r\n */\r\nexport function isHostedAuthEnvironment(): boolean {\r\n  if (typeof window === 'undefined') {\r\n    return false;\r\n  }\r\n\r\n  const { hostname, port, protocol } = window.location;\r\n\r\n  // Local development\r\n  if (hostname === 'localhost' && port === '7130') {\r\n    return true;\r\n  }\r\n\r\n  // Production hosted auth\r\n  if (protocol === 'https:' && hostname.endsWith('.insforge.app')) {\r\n    return true;\r\n  }\r\n\r\n  return false;\r\n}\r\n\r\n/**\r\n * Session data for building legacy auth URL\r\n */\r\nexport interface LegacyAuthSession {\r\n  accessToken: string;\r\n  userId: string;\r\n  email: string;\r\n  name?: string;\r\n  csrfToken?: string;\r\n}\r\n\r\n/**\r\n * Build a legacy flow redirect URL with auth params in query string\r\n *\r\n * This is used to pass authentication credentials back to the user's app\r\n * after OAuth completes in the hosted auth environment.\r\n *\r\n * @param redirectUrl - The URL to redirect to (user's app)\r\n * @param session - The session data to include in the URL\r\n * @returns The complete URL with auth params\r\n */\r\nexport function buildLegacyAuthUrl(redirectUrl: string, session: LegacyAuthSession): string {\r\n  const url = new URL(redirectUrl);\r\n  url.searchParams.set('access_token', session.accessToken);\r\n  url.searchParams.set('user_id', session.userId);\r\n  url.searchParams.set('email', session.email);\r\n\r\n  if (session.name) {\r\n    url.searchParams.set('name', session.name);\r\n  }\r\n\r\n  if (session.csrfToken) {\r\n    url.searchParams.set('csrf_token', session.csrfToken);\r\n  }\r\n\r\n  return url.toString();\r\n}\r\n","import { useState, useEffect, useRef, FormEvent } from 'react';\r\nimport { useSearchParams } from '../navigation';\r\nimport type { OAuthProvidersSchema } from '@insforge/shared-schemas';\r\nimport { useInsforge } from '../provider/InsforgeProvider';\r\nimport { usePublicAuthConfig } from '../hooks/usePublicAuthConfig';\r\nimport { SignInForm } from './forms/SignInForm';\r\nimport {\r\n  isHostedAuthEnvironment,\r\n  buildLegacyAuthUrl,\r\n  getCsrfTokenFromCookie,\r\n} from '../lib/hosted-auth';\r\n\r\ntype SignInStep = 'form' | 'awaiting-verification';\r\n\r\nexport interface SignInProps {\r\n  title?: string;\r\n  subtitle?: string;\r\n  emailLabel?: string;\r\n  emailPlaceholder?: string;\r\n  passwordLabel?: string;\r\n  passwordPlaceholder?: string;\r\n  forgotPasswordText?: string;\r\n  forgotPasswordUrl?: string;\r\n  submitButtonText?: string;\r\n  loadingButtonText?: string;\r\n  signUpText?: string;\r\n  signUpLinkText?: string;\r\n  signUpUrl?: string;\r\n  dividerText?: string;\r\n  onError?: (error: Error) => void;\r\n}\r\n\r\n/**\r\n * Pre-built sign-in component with full authentication logic.\r\n *\r\n * @component\r\n * @example\r\n * ```tsx\r\n * <SignIn\r\n *   onError={(error) => console.error('Error:', error)}\r\n * />\r\n * ```\r\n */\r\nexport function SignIn({ onError, ...uiProps }: SignInProps) {\r\n  const { signIn, verifyEmail, loginWithOAuth, isSignedIn, getSession, afterSignInUrl } =\r\n    useInsforge();\r\n  const { authConfig } = usePublicAuthConfig();\r\n  const [email, setEmail] = useState('');\r\n  const [password, setPassword] = useState('');\r\n  const [error, setError] = useState('');\r\n  const [loading, setLoading] = useState(false);\r\n  const [step, setStep] = useState<SignInStep>('form');\r\n  const [oauthLoading] = useState<OAuthProvidersSchema | null>(null);\r\n\r\n  const searchParams = useSearchParams();\r\n  const redirectUrl = searchParams.get('redirect');\r\n\r\n  // Track if we're handling OAuth completion redirect\r\n  const isHandlingOAuthRedirectRef = useRef(false);\r\n\r\n  // Handle OAuth completion: redirect back to user app with legacy flow params\r\n  useEffect(() => {\r\n    async function handleOAuthComplete() {\r\n      // Skip if not signed in or already handling\r\n      if (!isSignedIn || isHandlingOAuthRedirectRef.current) return;\r\n\r\n      const isHosted = isHostedAuthEnvironment();\r\n\r\n      if (isHosted && redirectUrl) {\r\n        // Hosted auth: redirect back to user app with legacy flow params\r\n        isHandlingOAuthRedirectRef.current = true;\r\n\r\n        try {\r\n          const session = await getSession();\r\n          if (!session) {\r\n            isHandlingOAuthRedirectRef.current = false;\r\n            return;\r\n          }\r\n\r\n          const csrfToken = getCsrfTokenFromCookie();\r\n          const legacyUrl = buildLegacyAuthUrl(redirectUrl, {\r\n            accessToken: session.accessToken,\r\n            userId: session.user.id,\r\n            email: session.user.email,\r\n            name: session.user.profile?.name || '',\r\n            csrfToken: csrfToken || undefined,\r\n          });\r\n\r\n          window.location.href = legacyUrl;\r\n        } catch (err) {\r\n          console.error('Failed to redirect after OAuth:', err);\r\n          isHandlingOAuthRedirectRef.current = false;\r\n        }\r\n      } else if (!isHosted) {\r\n        // Custom auth: redirect to afterSignInUrl or redirectUrl\r\n        const finalUrl = redirectUrl || afterSignInUrl || '/';\r\n        window.location.href = new URL(finalUrl, window.location.origin).toString();\r\n      }\r\n    }\r\n\r\n    void handleOAuthComplete();\r\n  }, [isSignedIn, redirectUrl, getSession, afterSignInUrl]);\r\n\r\n  async function handleSubmit(e: FormEvent<HTMLFormElement>) {\r\n    e.preventDefault();\r\n    setLoading(true);\r\n    setError('');\r\n\r\n    try {\r\n      const result = await signIn(email, password);\r\n      if ('error' in result) {\r\n        // Check if email verification is required (403 status code)\r\n        if (result.statusCode === 403) {\r\n          setStep('awaiting-verification');\r\n          setLoading(false);\r\n          return;\r\n        }\r\n        throw new Error(result.error);\r\n      }\r\n      const { user, accessToken, redirectTo, csrfToken } = result;\r\n      if (user) {\r\n        // Send back credentials to the redirect URL if no verification is required\r\n        const finalUrl = new URL(redirectTo || redirectUrl || '', window.location.origin);\r\n        finalUrl.searchParams.set('access_token', accessToken);\r\n        finalUrl.searchParams.set('user_id', user.id);\r\n        finalUrl.searchParams.set('email', user.email);\r\n        finalUrl.searchParams.set('name', user.profile?.name || '');\r\n        if (csrfToken) {\r\n          finalUrl.searchParams.set('csrf_token', csrfToken);\r\n        }\r\n        window.location.href = finalUrl.toString();\r\n      }\r\n    } catch (err: unknown) {\r\n      const errorMessage = err instanceof Error ? err.message : 'Sign in failed';\r\n      setError(errorMessage);\r\n      if (onError) {\r\n        onError(new Error(errorMessage));\r\n      }\r\n    } finally {\r\n      setLoading(false);\r\n    }\r\n  }\r\n\r\n  async function handleVerifyCode(code: string) {\r\n    setError('');\r\n    try {\r\n      const result = await verifyEmail(code, email);\r\n\r\n      if ('error' in result) {\r\n        throw new Error('Verification failed');\r\n      }\r\n\r\n      // Send back credentials to the redirect URL if verification code is successful\r\n      const finalUrl = new URL(result.redirectTo || redirectUrl || '', window.location.origin);\r\n      finalUrl.searchParams.set('access_token', result.accessToken);\r\n      finalUrl.searchParams.set('user_id', result.user.id);\r\n      finalUrl.searchParams.set('email', result.user.email);\r\n      finalUrl.searchParams.set('name', result.user.profile?.name || '');\r\n      if (result.csrfToken) {\r\n        finalUrl.searchParams.set('csrf_token', result.csrfToken);\r\n      }\r\n      window.location.href = finalUrl.toString();\r\n    } catch (err: unknown) {\r\n      const errorMessage = err instanceof Error ? err.message : 'Invalid verification code';\r\n      setError(errorMessage);\r\n    }\r\n  }\r\n\r\n  function handleOAuth(provider: OAuthProvidersSchema) {\r\n    try {\r\n      // Always use current page URL as redirect_uri\r\n      // This ensures OAuth callback returns to this page, where PKCE can be completed\r\n      // (sessionStorage is per-origin, so callback must return to same origin)\r\n      void loginWithOAuth(provider, window.location.href);\r\n    } catch (err: unknown) {\r\n      const errorMessage = err instanceof Error ? err.message : 'OAuth login failed';\r\n      setError(errorMessage);\r\n      if (onError) {\r\n        onError(new Error(errorMessage));\r\n      }\r\n    }\r\n  }\r\n\r\n  // If email auth is disabled after loading, don't show the form\r\n  if (!authConfig) {\r\n    return null;\r\n  }\r\n\r\n  return (\r\n    <SignInForm\r\n      email={email}\r\n      password={password}\r\n      onEmailChange={setEmail}\r\n      onPasswordChange={setPassword}\r\n      onSubmit={(e) => void handleSubmit(e)}\r\n      error={error}\r\n      loading={loading}\r\n      oauthLoading={oauthLoading}\r\n      onOAuthClick={handleOAuth}\r\n      authConfig={authConfig}\r\n      showVerificationStep={step === 'awaiting-verification'}\r\n      onVerifyCode={handleVerifyCode}\r\n      {...uiProps}\r\n    />\r\n  );\r\n}\r\n","import {\r\n  AuthContainer,\r\n  AuthHeader,\r\n  AuthErrorBanner,\r\n  AuthFormField,\r\n  AuthPasswordField,\r\n  AuthSubmitButton,\r\n  AuthLink,\r\n  AuthDivider,\r\n  AuthOAuthProviders,\r\n  AuthEmailVerificationStep,\r\n} from '../atoms';\r\nimport type { OAuthProvidersSchema } from '@insforge/shared-schemas';\r\nimport type { FormEvent } from 'react';\r\nimport type { AuthConfig } from '../../types';\r\nimport { theme } from '../../styles/theme';\r\n\r\nexport interface SignUpFormProps {\r\n  email: string;\r\n  password: string;\r\n  onEmailChange: (email: string) => void;\r\n  onPasswordChange: (password: string) => void;\r\n  onSubmit: (e: FormEvent<HTMLFormElement>) => void;\r\n  error?: string;\r\n  loading?: boolean;\r\n  oauthLoading?: OAuthProvidersSchema | null;\r\n  onOAuthClick?: (provider: OAuthProvidersSchema) => void;\r\n  authConfig: AuthConfig;\r\n  title?: string;\r\n  subtitle?: string;\r\n  emailLabel?: string;\r\n  emailPlaceholder?: string;\r\n  passwordLabel?: string;\r\n  passwordPlaceholder?: string;\r\n  submitButtonText?: string;\r\n  loadingButtonText?: string;\r\n  signInText?: string;\r\n  signInLinkText?: string;\r\n  signInUrl?: string;\r\n  dividerText?: string;\r\n  showVerificationStep?: boolean;\r\n  onVerifyCode?: (code: string) => Promise<void>;\r\n}\r\n\r\n/**\r\n * Pre-built sign-up form component (UI only, no business logic).\r\n */\r\nexport function SignUpForm({\r\n  email,\r\n  password,\r\n  onEmailChange,\r\n  onPasswordChange,\r\n  onSubmit,\r\n  error,\r\n  loading = false,\r\n  oauthLoading = null,\r\n  onOAuthClick,\r\n  authConfig,\r\n  title = 'Get Started',\r\n  subtitle = 'Create your account',\r\n  emailLabel = 'Email',\r\n  emailPlaceholder = 'example@email.com',\r\n  passwordLabel = 'Password',\r\n  passwordPlaceholder = '••••••',\r\n  submitButtonText = 'Sign Up',\r\n  loadingButtonText = 'Creating account...',\r\n  signInText = 'Already have an account?',\r\n  signInLinkText = 'Login Now',\r\n  signInUrl = '/sign-in',\r\n  dividerText = 'or',\r\n  showVerificationStep = false,\r\n  onVerifyCode,\r\n}: SignUpFormProps) {\r\n  return (\r\n    <AuthContainer>\r\n      <AuthHeader title={title} subtitle={subtitle} />\r\n\r\n      <AuthErrorBanner error={error || ''} />\r\n\r\n      {showVerificationStep ? (\r\n        <AuthEmailVerificationStep\r\n          email={email}\r\n          method={authConfig.verifyEmailMethod}\r\n          onVerifyCode={onVerifyCode}\r\n          emailSent={true}\r\n        />\r\n      ) : (\r\n        <form\r\n          onSubmit={onSubmit}\r\n          noValidate\r\n          style={{ display: 'flex', flexDirection: 'column', gap: theme.spacing[6] }}\r\n        >\r\n          <AuthFormField\r\n            id=\"email\"\r\n            type=\"email\"\r\n            label={emailLabel}\r\n            placeholder={emailPlaceholder}\r\n            value={email}\r\n            onChange={(e) => onEmailChange(e.target.value)}\r\n            required\r\n            autoComplete=\"email\"\r\n          />\r\n\r\n          <AuthPasswordField\r\n            id=\"password\"\r\n            label={passwordLabel}\r\n            placeholder={passwordPlaceholder}\r\n            value={password}\r\n            onChange={(e) => onPasswordChange(e.target.value)}\r\n            required\r\n            autoComplete=\"new-password\"\r\n            showStrengthIndicator\r\n            authConfig={authConfig}\r\n          />\r\n\r\n          <AuthSubmitButton isLoading={loading} disabled={loading || oauthLoading !== null}>\r\n            {loading ? loadingButtonText : submitButtonText}\r\n          </AuthSubmitButton>\r\n        </form>\r\n      )}\r\n\r\n      {!showVerificationStep && (\r\n        <>\r\n          <AuthLink text={signInText} linkText={signInLinkText} href={signInUrl} />\r\n\r\n          {authConfig.oAuthProviders.length > 0 && onOAuthClick && (\r\n            <>\r\n              <AuthDivider text={dividerText} />\r\n              <AuthOAuthProviders\r\n                providers={authConfig.oAuthProviders}\r\n                onClick={onOAuthClick}\r\n                disabled={loading || oauthLoading !== null}\r\n                loading={oauthLoading}\r\n              />\r\n            </>\r\n          )}\r\n        </>\r\n      )}\r\n    </AuthContainer>\r\n  );\r\n}\r\n","import { z } from 'zod';\r\n\r\n/**\r\n * Email validation schema\r\n */\r\nexport const emailSchema = z.string().min(1, 'Email is required').email('Invalid email address');\r\n\r\n/**\r\n * Password validation schema with configurable requirements\r\n */\r\nexport function createPasswordSchema(options?: {\r\n  minLength?: number;\r\n  requireUppercase?: boolean;\r\n  requireLowercase?: boolean;\r\n  requireNumber?: boolean;\r\n  requireSpecialChar?: boolean;\r\n}) {\r\n  const {\r\n    minLength = 6,\r\n    requireUppercase = false,\r\n    requireLowercase = false,\r\n    requireNumber = false,\r\n    requireSpecialChar = false,\r\n  } = options || {};\r\n\r\n  let schema = z.string().min(minLength, `Password must be at least ${minLength} characters`);\r\n\r\n  if (requireUppercase) {\r\n    schema = schema.regex(/[A-Z]/, 'Password must contain at least one uppercase letter');\r\n  }\r\n\r\n  if (requireLowercase) {\r\n    schema = schema.regex(/[a-z]/, 'Password must contain at least one lowercase letter');\r\n  }\r\n\r\n  if (requireNumber) {\r\n    schema = schema.regex(/\\d/, 'Password must contain at least one number');\r\n  }\r\n\r\n  if (requireSpecialChar) {\r\n    schema = schema.regex(\r\n      /[!@#$%^&*()_+\\-=[\\]{};':\"\\\\|,.<>/?]/,\r\n      'Password must contain at least one special character'\r\n    );\r\n  }\r\n\r\n  return schema;\r\n}\r\n\r\n/**\r\n * Default password schema (minimum 6 characters)\r\n */\r\nexport const passwordSchema = createPasswordSchema();\r\n\r\n/**\r\n * Validate email format\r\n */\r\nexport function validateEmail(email: string): { valid: boolean; error?: string } {\r\n  const result = emailSchema.safeParse(email);\r\n  if (result.success) {\r\n    return { valid: true };\r\n  }\r\n  return { valid: false, error: result.error.message };\r\n}\r\n\r\n/**\r\n * Validate password format\r\n */\r\nexport function validatePassword(\r\n  password: string,\r\n  options?: Parameters<typeof createPasswordSchema>[0]\r\n): { valid: boolean; error?: string } {\r\n  const schema = createPasswordSchema(options);\r\n  const result = schema.safeParse(password);\r\n  if (result.success) {\r\n    return { valid: true };\r\n  }\r\n  return { valid: false, error: result.error.message };\r\n}\r\n\r\n/**\r\n * Validate password strength based on multiple criteria\r\n */\r\nexport function checkPasswordStrength(password: string): {\r\n  score: number;\r\n  feedback: string[];\r\n} {\r\n  const feedback: string[] = [];\r\n  let score = 0;\r\n\r\n  if (password.length >= 8) {\r\n    score += 1;\r\n  } else {\r\n    feedback.push('Use at least 8 characters');\r\n  }\r\n\r\n  if (password.length >= 12) {\r\n    score += 1;\r\n  }\r\n\r\n  if (/[a-z]/.test(password) && /[A-Z]/.test(password)) {\r\n    score += 1;\r\n  } else {\r\n    feedback.push('Use both uppercase and lowercase letters');\r\n  }\r\n\r\n  if (/\\d/.test(password)) {\r\n    score += 1;\r\n  } else {\r\n    feedback.push('Include at least one number');\r\n  }\r\n\r\n  if (/[!@#$%^&*()_+\\-=[\\]{};':\"\\\\|,.<>/?]/.test(password)) {\r\n    score += 1;\r\n  } else {\r\n    feedback.push('Include at least one special character');\r\n  }\r\n\r\n  return { score, feedback };\r\n}\r\n","import { useState, useEffect, useRef, FormEvent } from 'react';\r\nimport { useSearchParams } from '../navigation';\r\nimport type { OAuthProvidersSchema } from '@insforge/shared-schemas';\r\nimport { useInsforge } from '../provider/InsforgeProvider';\r\nimport { usePublicAuthConfig } from '../hooks/usePublicAuthConfig';\r\nimport { SignUpForm } from './forms/SignUpForm';\r\nimport { emailSchema, createPasswordSchema } from '../lib/validation';\r\nimport {\r\n  isHostedAuthEnvironment,\r\n  buildLegacyAuthUrl,\r\n  getCsrfTokenFromCookie,\r\n} from '../lib/hosted-auth';\r\n\r\ntype SignUpStep = 'form' | 'awaiting-verification';\r\n\r\nexport interface SignUpProps {\r\n  title?: string;\r\n  subtitle?: string;\r\n  emailLabel?: string;\r\n  emailPlaceholder?: string;\r\n  passwordLabel?: string;\r\n  passwordPlaceholder?: string;\r\n  submitButtonText?: string;\r\n  loadingButtonText?: string;\r\n  signInText?: string;\r\n  signInLinkText?: string;\r\n  signInUrl?: string;\r\n  dividerText?: string;\r\n  onError?: (error: Error) => void;\r\n  emailRedirectTo?: string;\r\n}\r\n\r\n/**\r\n * Pre-built sign-up component with full authentication logic.\r\n *\r\n * @component\r\n * @example\r\n * ```tsx\r\n * <SignUp\r\n *   onError={(error) => console.error('Error:', error)}\r\n * />\r\n *\r\n * ```\r\n */\r\nexport function SignUp({ onError, emailRedirectTo, ...uiProps }: SignUpProps) {\r\n  const { signUp, verifyEmail, loginWithOAuth, isSignedIn, getSession, afterSignInUrl } =\r\n    useInsforge();\r\n  const { authConfig } = usePublicAuthConfig();\r\n  const [email, setEmail] = useState('');\r\n  const [password, setPassword] = useState('');\r\n  const [error, setError] = useState('');\r\n  const [loading, setLoading] = useState(false);\r\n  const [step, setStep] = useState<SignUpStep>('form');\r\n  const [oauthLoading] = useState<OAuthProvidersSchema | null>(null);\r\n\r\n  const searchParams = useSearchParams();\r\n  const redirectUrl = searchParams.get('redirect');\r\n\r\n  // Track if we're handling OAuth completion redirect\r\n  const isHandlingOAuthRedirectRef = useRef(false);\r\n\r\n  // Handle OAuth completion: redirect back to user app with legacy flow params\r\n  useEffect(() => {\r\n    async function handleOAuthComplete() {\r\n      // Skip if not signed in or already handling\r\n      if (!isSignedIn || isHandlingOAuthRedirectRef.current) return;\r\n\r\n      const isHosted = isHostedAuthEnvironment();\r\n\r\n      if (isHosted && redirectUrl) {\r\n        // Hosted auth: redirect back to user app with legacy flow params\r\n        isHandlingOAuthRedirectRef.current = true;\r\n\r\n        try {\r\n          const session = await getSession();\r\n          if (!session) {\r\n            isHandlingOAuthRedirectRef.current = false;\r\n            return;\r\n          }\r\n\r\n          const csrfToken = getCsrfTokenFromCookie();\r\n          const legacyUrl = buildLegacyAuthUrl(redirectUrl, {\r\n            accessToken: session.accessToken,\r\n            userId: session.user.id,\r\n            email: session.user.email,\r\n            name: session.user.profile?.name || '',\r\n            csrfToken: csrfToken || undefined,\r\n          });\r\n\r\n          window.location.href = legacyUrl;\r\n        } catch (err) {\r\n          console.error('Failed to redirect after OAuth:', err);\r\n          isHandlingOAuthRedirectRef.current = false;\r\n        }\r\n      } else if (!isHosted) {\r\n        // Custom auth: redirect to afterSignInUrl or redirectUrl\r\n        const finalUrl = redirectUrl || afterSignInUrl || '/';\r\n        window.location.href = new URL(finalUrl, window.location.origin).toString();\r\n      }\r\n    }\r\n\r\n    void handleOAuthComplete();\r\n  }, [isSignedIn, redirectUrl, getSession, afterSignInUrl]);\r\n\r\n  async function handleSubmit(e: FormEvent<HTMLFormElement>) {\r\n    e.preventDefault();\r\n    setLoading(true);\r\n    setError('');\r\n\r\n    // Check if authConfig is loaded\r\n    if (!authConfig) {\r\n      setError('Configuration not loaded. Please refresh the page.');\r\n      setLoading(false);\r\n      return;\r\n    }\r\n\r\n    // Validate email using Zod schema\r\n    const emailValidation = emailSchema.safeParse(email);\r\n    if (!emailValidation.success) {\r\n      const firstError = emailValidation.error.issues[0];\r\n      setError(firstError.message);\r\n      setLoading(false);\r\n      return;\r\n    }\r\n\r\n    // Validate password using dynamic Zod schema based on config\r\n    const passwordZodSchema = createPasswordSchema({\r\n      minLength: authConfig.passwordMinLength,\r\n      requireUppercase: authConfig.requireUppercase,\r\n      requireLowercase: authConfig.requireLowercase,\r\n      requireNumber: authConfig.requireNumber,\r\n      requireSpecialChar: authConfig.requireSpecialChar,\r\n    });\r\n\r\n    const passwordValidation = passwordZodSchema.safeParse(password);\r\n    if (!passwordValidation.success) {\r\n      const firstError = passwordValidation.error.issues[0];\r\n      setError(firstError.message);\r\n      setLoading(false);\r\n      return;\r\n    }\r\n\r\n    try {\r\n      const result = await signUp(emailValidation.data, password, { emailRedirectTo });\r\n      if ('error' in result) {\r\n        throw new Error(result.error);\r\n      }\r\n\r\n      // Check if email verification is required\r\n      if (result.requireEmailVerification) {\r\n        setStep('awaiting-verification');\r\n        setLoading(false);\r\n        return;\r\n      }\r\n\r\n      // If we have an access token, proceed with success callback\r\n      if (result.accessToken && result.user) {\r\n        // Send back credentials to the redirect URL if no verification is required\r\n        const csrfToken = result.csrfToken;\r\n        const finalUrl = new URL(result.redirectTo || redirectUrl || '', window.location.origin);\r\n        finalUrl.searchParams.set('access_token', result.accessToken);\r\n        finalUrl.searchParams.set('user_id', result.user.id);\r\n        finalUrl.searchParams.set('email', result.user.email);\r\n        finalUrl.searchParams.set('name', result.user.profile?.name || '');\r\n        if (csrfToken) {\r\n          finalUrl.searchParams.set('csrf_token', csrfToken);\r\n        }\r\n        window.location.href = finalUrl.toString();\r\n      }\r\n    } catch (err: unknown) {\r\n      const errorMessage = err instanceof Error ? err.message : 'Sign up failed';\r\n      setError(errorMessage);\r\n      if (onError) {\r\n        onError(new Error(errorMessage));\r\n      }\r\n    } finally {\r\n      setLoading(false);\r\n    }\r\n  }\r\n\r\n  async function handleVerifyCode(code: string) {\r\n    setError('');\r\n    try {\r\n      const result = await verifyEmail(code, email);\r\n\r\n      if ('error' in result) {\r\n        throw new Error('Verification failed');\r\n      }\r\n\r\n      // Send back credentials to the redirect URL if verification code is successful\r\n      const finalUrl = new URL(result.redirectTo || redirectUrl || '', window.location.origin);\r\n      finalUrl.searchParams.set('access_token', result.accessToken);\r\n      finalUrl.searchParams.set('user_id', result.user.id);\r\n      finalUrl.searchParams.set('email', result.user.email);\r\n      finalUrl.searchParams.set('name', result.user.profile?.name || '');\r\n      if (result.csrfToken) {\r\n        finalUrl.searchParams.set('csrf_token', result.csrfToken);\r\n      }\r\n      window.location.href = finalUrl.toString();\r\n    } catch (err: unknown) {\r\n      const errorMessage = err instanceof Error ? err.message : 'Invalid verification code';\r\n      setError(errorMessage);\r\n    }\r\n  }\r\n\r\n  function handleOAuth(provider: OAuthProvidersSchema) {\r\n    try {\r\n      // Always use current page URL as redirect_uri\r\n      // This ensures OAuth callback returns to this page, where PKCE can be completed\r\n      // (sessionStorage is per-origin, so callback must return to same origin)\r\n      void loginWithOAuth(provider, window.location.href);\r\n    } catch (err: unknown) {\r\n      const errorMessage = err instanceof Error ? err.message : 'OAuth login failed';\r\n      setError(errorMessage);\r\n      if (onError) {\r\n        onError(new Error(errorMessage));\r\n      }\r\n    }\r\n  }\r\n\r\n  // If email auth is disabled after loading, don't show the form\r\n  if (!authConfig) {\r\n    return null;\r\n  }\r\n\r\n  return (\r\n    <SignUpForm\r\n      email={email}\r\n      password={password}\r\n      onEmailChange={setEmail}\r\n      onPasswordChange={setPassword}\r\n      onSubmit={(e) => void handleSubmit(e)}\r\n      error={error}\r\n      loading={loading}\r\n      oauthLoading={oauthLoading}\r\n      onOAuthClick={handleOAuth}\r\n      authConfig={authConfig}\r\n      showVerificationStep={step === 'awaiting-verification'}\r\n      onVerifyCode={handleVerifyCode}\r\n      {...uiProps}\r\n    />\r\n  );\r\n}\r\n","import {\r\n  AuthContainer,\r\n  AuthHeader,\r\n  AuthErrorBanner,\r\n  AuthFormField,\r\n  AuthSubmitButton,\r\n  AuthLink,\r\n  AuthResetPasswordVerificationStep,\r\n} from '../atoms';\r\nimport type { FormEvent } from 'react';\r\nimport { theme } from '../../styles/theme';\r\n\r\ntype ResetPasswordMethod = 'code' | 'link';\r\n\r\nexport interface ForgotPasswordFormProps {\r\n  email: string;\r\n  onEmailChange: (email: string) => void;\r\n  onSubmit: (e: FormEvent<HTMLFormElement>) => void;\r\n  error?: string;\r\n  loading?: boolean;\r\n  title?: string;\r\n  subtitle?: string;\r\n  emailLabel?: string;\r\n  emailPlaceholder?: string;\r\n  submitButtonText?: string;\r\n  loadingButtonText?: string;\r\n  backToSignInText?: string;\r\n  backToSignInUrl?: string;\r\n  showVerificationStep?: boolean;\r\n  resetPasswordMethod?: ResetPasswordMethod;\r\n  onVerifyCode?: (code: string) => Promise<void>;\r\n  onResendEmail?: () => Promise<void>;\r\n}\r\n\r\n/**\r\n * Pre-built forgot password form component (UI only, no business logic).\r\n */\r\nexport function ForgotPasswordForm({\r\n  email,\r\n  onEmailChange,\r\n  onSubmit,\r\n  error,\r\n  loading = false,\r\n  title = 'Forgot Password?',\r\n  subtitle = \"Enter your email address and we'll send you a {method} to reset your password.\",\r\n  emailLabel = 'Email',\r\n  emailPlaceholder = 'example@email.com',\r\n  submitButtonText = 'Reset Password',\r\n  loadingButtonText = 'Sending...',\r\n  backToSignInText = 'Remember your password?',\r\n  backToSignInUrl = '/sign-in',\r\n  showVerificationStep = false,\r\n  resetPasswordMethod = 'code',\r\n  onVerifyCode,\r\n  onResendEmail,\r\n}: ForgotPasswordFormProps) {\r\n  const displaySubtitle = subtitle.replace('{method}', resetPasswordMethod);\r\n\r\n  return (\r\n    <AuthContainer>\r\n      <AuthHeader title={title} subtitle={displaySubtitle} />\r\n\r\n      <AuthErrorBanner error={error || ''} />\r\n\r\n      {showVerificationStep ? (\r\n        <AuthResetPasswordVerificationStep\r\n          email={email}\r\n          method={resetPasswordMethod}\r\n          onVerifyCode={onVerifyCode}\r\n          onResendEmail={onResendEmail || (async () => {})}\r\n        />\r\n      ) : (\r\n        <form\r\n          onSubmit={onSubmit}\r\n          noValidate\r\n          style={{ display: 'flex', flexDirection: 'column', gap: theme.spacing[6] }}\r\n        >\r\n          <AuthFormField\r\n            id=\"email\"\r\n            type=\"email\"\r\n            label={emailLabel}\r\n            placeholder={emailPlaceholder}\r\n            value={email}\r\n            onChange={(e) => onEmailChange(e.target.value)}\r\n            required\r\n            autoComplete=\"email\"\r\n          />\r\n\r\n          <AuthSubmitButton isLoading={loading} disabled={loading}>\r\n            {loading ? loadingButtonText : submitButtonText}\r\n          </AuthSubmitButton>\r\n        </form>\r\n      )}\r\n\r\n      {!showVerificationStep && (\r\n        <AuthLink text={backToSignInText} linkText=\"Back to Sign In\" href={backToSignInUrl} />\r\n      )}\r\n    </AuthContainer>\r\n  );\r\n}\r\n","import {\r\n  AuthContainer,\r\n  AuthHeader,\r\n  AuthErrorBanner,\r\n  AuthPasswordField,\r\n  AuthSubmitButton,\r\n} from '../atoms';\r\nimport type { FormEvent } from 'react';\r\nimport type { AuthConfig } from '../../types';\r\nimport { theme } from '../../styles/theme';\r\nimport {\r\n  VerifyStatusContainer,\r\n  VerifyStatusSuccessContent,\r\n  VerifyStatusSuccessIcon,\r\n  VerifyStatusSuccessIconSvg,\r\n  VerifyStatusTextCenter,\r\n} from './styled';\r\n\r\nexport interface ResetPasswordFormProps {\r\n  newPassword: string;\r\n  confirmPassword: string;\r\n  onNewPasswordChange: (password: string) => void;\r\n  onConfirmPasswordChange: (password: string) => void;\r\n  onSubmit: (e: FormEvent<HTMLFormElement>) => void;\r\n  error?: string;\r\n  loading?: boolean;\r\n  success?: boolean;\r\n  authConfig: AuthConfig;\r\n  title?: string;\r\n  subtitle?: string;\r\n  newPasswordLabel?: string;\r\n  newPasswordPlaceholder?: string;\r\n  confirmPasswordLabel?: string;\r\n  confirmPasswordPlaceholder?: string;\r\n  submitButtonText?: string;\r\n  loadingButtonText?: string;\r\n  successTitle?: string;\r\n}\r\n\r\n/**\r\n * Pre-built reset password form component (UI only, no business logic).\r\n */\r\nexport function ResetPasswordForm({\r\n  newPassword,\r\n  confirmPassword,\r\n  onNewPasswordChange,\r\n  onConfirmPasswordChange,\r\n  onSubmit,\r\n  error,\r\n  loading = false,\r\n  success = false,\r\n  authConfig,\r\n  title = 'Reset Password',\r\n  subtitle = 'Enter your new password below.',\r\n  newPasswordLabel = 'New Password',\r\n  newPasswordPlaceholder = '••••••',\r\n  confirmPasswordLabel = 'Confirm Password',\r\n  confirmPasswordPlaceholder = '••••••',\r\n  submitButtonText = 'Reset Password',\r\n  loadingButtonText = 'Resetting...',\r\n  successTitle = 'Password Reset Successful!',\r\n}: ResetPasswordFormProps) {\r\n  let successMessage =\r\n    'Your password has been successfully reset. You can close this page and sign in with your new password.';\r\n  if (authConfig && authConfig.verifyEmailMethod === 'code') {\r\n    successMessage =\r\n      'Your password has been successfully reset. You can wait for redirect to sign in with your new password.';\r\n  }\r\n\r\n  // Success state\r\n  if (success) {\r\n    return (\r\n      <AuthContainer>\r\n        <VerifyStatusContainer $stretch>\r\n          <VerifyStatusSuccessContent>\r\n            <VerifyStatusSuccessIcon>\r\n              <VerifyStatusSuccessIconSvg>\r\n                <svg\r\n                  fill=\"none\"\r\n                  strokeLinecap=\"round\"\r\n                  strokeLinejoin=\"round\"\r\n                  strokeWidth=\"2\"\r\n                  viewBox=\"0 0 24 24\"\r\n                  stroke=\"currentColor\"\r\n                >\r\n                  <path d=\"M5 13l4 4L19 7\" />\r\n                </svg>\r\n              </VerifyStatusSuccessIconSvg>\r\n            </VerifyStatusSuccessIcon>\r\n            <VerifyStatusTextCenter style={{ fontSize: '1.5rem', fontWeight: 600 }}>\r\n              {successTitle}\r\n            </VerifyStatusTextCenter>\r\n            <VerifyStatusTextCenter style={{ color: theme.colors.textSecondary }}>\r\n              {successMessage}\r\n            </VerifyStatusTextCenter>\r\n          </VerifyStatusSuccessContent>\r\n        </VerifyStatusContainer>\r\n      </AuthContainer>\r\n    );\r\n  }\r\n\r\n  return (\r\n    <AuthContainer>\r\n      <AuthHeader title={title} subtitle={subtitle} />\r\n\r\n      <AuthErrorBanner error={error || ''} />\r\n\r\n      <form\r\n        onSubmit={onSubmit}\r\n        noValidate\r\n        style={{ display: 'flex', flexDirection: 'column', gap: theme.spacing[6] }}\r\n      >\r\n        <AuthPasswordField\r\n          id=\"newPassword\"\r\n          label={newPasswordLabel}\r\n          placeholder={newPasswordPlaceholder}\r\n          value={newPassword}\r\n          onChange={(e) => onNewPasswordChange(e.target.value)}\r\n          required\r\n          autoComplete=\"new-password\"\r\n          showStrengthIndicator\r\n          authConfig={authConfig}\r\n        />\r\n\r\n        <AuthPasswordField\r\n          id=\"confirmPassword\"\r\n          label={confirmPasswordLabel}\r\n          placeholder={confirmPasswordPlaceholder}\r\n          value={confirmPassword}\r\n          onChange={(e) => onConfirmPasswordChange(e.target.value)}\r\n          required\r\n          autoComplete=\"new-password\"\r\n          authConfig={authConfig}\r\n        />\r\n\r\n        <AuthSubmitButton isLoading={loading} disabled={loading}>\r\n          {loading ? loadingButtonText : submitButtonText}\r\n        </AuthSubmitButton>\r\n      </form>\r\n    </AuthContainer>\r\n  );\r\n}\r\n","import { useState, FormEvent } from 'react';\r\nimport { useSearchParams } from '../navigation';\r\nimport { useInsforge } from '../provider/InsforgeProvider';\r\nimport { usePublicAuthConfig } from '../hooks/usePublicAuthConfig';\r\nimport { ForgotPasswordForm } from './forms/ForgotPasswordForm';\r\nimport { ResetPasswordForm } from './forms/ResetPasswordForm';\r\nimport { emailSchema, createPasswordSchema } from '../lib/validation';\r\nimport { resolveAuthUrl } from '../lib/path-utils';\r\n\r\ntype ForgotPasswordStep = 'email' | 'password';\r\n\r\nexport interface ForgotPasswordProps {\r\n  /** Text customization */\r\n  title?: string;\r\n  subtitle?: string;\r\n  emailLabel?: string;\r\n  emailPlaceholder?: string;\r\n  submitButtonText?: string;\r\n  loadingButtonText?: string;\r\n  backToSignInText?: string;\r\n  /** Callback when an error occurs */\r\n  onError?: (error: Error) => void;\r\n}\r\n\r\n/**\r\n * Pre-built forgot password component with full business logic.\r\n *\r\n * Supports two password reset methods (auto-detected from backend config):\r\n * - **Link method**: Two-step flow (email → check email message)\r\n *   User receives an email with a reset link to complete the process in a new tab\r\n * - **Code method**: Three-step flow (email → verify code → reset password)\r\n *   User receives a verification code, enters it, then sets a new password\r\n *\r\n * @component\r\n * @example\r\n * ```tsx\r\n * <ForgotPassword\r\n *   onError={(error) => console.error('Error:', error)}\r\n * />\r\n * ```\r\n */\r\nexport function ForgotPassword({ onError, ...uiProps }: ForgotPasswordProps) {\r\n  const { sendResetPasswordEmail, exchangeResetPasswordToken, resetPassword } = useInsforge();\r\n  const { authConfig } = usePublicAuthConfig();\r\n  const searchParams = useSearchParams();\r\n\r\n  const [step, setStep] = useState<ForgotPasswordStep>('email');\r\n  const [email, setEmail] = useState('');\r\n  const [resetToken, setResetToken] = useState('');\r\n  const [newPassword, setNewPassword] = useState('');\r\n  const [confirmPassword, setConfirmPassword] = useState('');\r\n  const [error, setError] = useState('');\r\n  const [loading, setLoading] = useState(false);\r\n  const [success, setSuccess] = useState(false);\r\n  const [showVerificationStep, setShowVerificationStep] = useState(false);\r\n\r\n  // Step 1: Send reset email\r\n  async function handleEmailSubmit(e: FormEvent<HTMLFormElement>) {\r\n    e.preventDefault();\r\n    setLoading(true);\r\n    setError('');\r\n\r\n    // Validate email using Zod schema\r\n    const emailValidation = emailSchema.safeParse(email);\r\n    if (!emailValidation.success) {\r\n      const firstError = emailValidation.error.issues[0];\r\n      setError(firstError.message);\r\n      setLoading(false);\r\n      return;\r\n    }\r\n\r\n    try {\r\n      const result = await sendResetPasswordEmail(emailValidation.data);\r\n\r\n      if (result?.success) {\r\n        // Show verification step (link or code)\r\n        setShowVerificationStep(true);\r\n      } else {\r\n        const errorMessage = result?.message || 'Failed to send reset email';\r\n        setError(errorMessage);\r\n        if (onError) {\r\n          onError(new Error(errorMessage));\r\n        }\r\n      }\r\n    } catch (err: unknown) {\r\n      const errorMessage = err instanceof Error ? err.message : 'Failed to send reset email';\r\n      setError(errorMessage);\r\n      if (onError) {\r\n        onError(new Error(errorMessage));\r\n      }\r\n    } finally {\r\n      setLoading(false);\r\n    }\r\n  }\r\n\r\n  // Step 2: Verify code and get reset token (for code method)\r\n  async function handleVerifyCode(code: string) {\r\n    setError('');\r\n    try {\r\n      const result = await exchangeResetPasswordToken(email, code);\r\n\r\n      if ('error' in result) {\r\n        throw new Error(result.error.message || 'Failed to verify code');\r\n      }\r\n\r\n      if (result.token) {\r\n        setResetToken(result.token);\r\n        setStep('password');\r\n      }\r\n    } catch (err: unknown) {\r\n      const errorMessage = err instanceof Error ? err.message : 'Invalid verification code';\r\n      setError(errorMessage);\r\n      if (onError) {\r\n        onError(new Error(errorMessage));\r\n      }\r\n    }\r\n  }\r\n\r\n  // Resend reset email\r\n  async function handleResendEmail() {\r\n    await sendResetPasswordEmail(email);\r\n  }\r\n\r\n  // Step 3: Reset password\r\n  async function handleResetPasswordSubmit(e: FormEvent<HTMLFormElement>) {\r\n    e.preventDefault();\r\n    setLoading(true);\r\n    setError('');\r\n\r\n    // Check passwords match\r\n    if (newPassword !== confirmPassword) {\r\n      setError('Passwords do not match');\r\n      setLoading(false);\r\n      return;\r\n    }\r\n\r\n    // Validate password using dynamic Zod schema\r\n    if (!authConfig) {\r\n      setError('Configuration not loaded');\r\n      setLoading(false);\r\n      return;\r\n    }\r\n\r\n    const passwordZodSchema = createPasswordSchema({\r\n      minLength: authConfig.passwordMinLength,\r\n      requireUppercase: authConfig.requireUppercase,\r\n      requireLowercase: authConfig.requireLowercase,\r\n      requireNumber: authConfig.requireNumber,\r\n      requireSpecialChar: authConfig.requireSpecialChar,\r\n    });\r\n\r\n    const passwordValidation = passwordZodSchema.safeParse(newPassword);\r\n    if (!passwordValidation.success) {\r\n      const firstError = passwordValidation.error.issues[0];\r\n      setError(firstError.message);\r\n      setLoading(false);\r\n      return;\r\n    }\r\n\r\n    try {\r\n      const result = await resetPassword(resetToken, newPassword);\r\n\r\n      if (result?.message) {\r\n        setSuccess(true);\r\n        // Navigate to sign-in with all search params preserved and proper base path handling\r\n        const signInUrl = resolveAuthUrl('/sign-in', searchParams);\r\n        // Redirect after a short delay to show success message\r\n        setTimeout(() => {\r\n          window.location.href = signInUrl;\r\n        }, 2000);\r\n      } else {\r\n        const errorMessage = 'Failed to reset password';\r\n        setError(errorMessage);\r\n        if (onError) {\r\n          onError(new Error(errorMessage));\r\n        }\r\n      }\r\n    } catch (err: unknown) {\r\n      const errorMessage = err instanceof Error ? err.message : 'Failed to reset password';\r\n      setError(errorMessage);\r\n      if (onError) {\r\n        onError(new Error(errorMessage));\r\n      }\r\n    } finally {\r\n      setLoading(false);\r\n    }\r\n  }\r\n\r\n  // If email auth config not loaded yet\r\n  if (!authConfig) {\r\n    return null;\r\n  }\r\n\r\n  // Step 1 & 2: Email input and verification (handled by ForgotPasswordForm)\r\n  if (step === 'email') {\r\n    return (\r\n      <ForgotPasswordForm\r\n        email={email}\r\n        onEmailChange={setEmail}\r\n        onSubmit={(e) => {\r\n          void handleEmailSubmit(e);\r\n        }}\r\n        error={error}\r\n        loading={loading}\r\n        showVerificationStep={showVerificationStep}\r\n        resetPasswordMethod={authConfig.resetPasswordMethod}\r\n        onVerifyCode={handleVerifyCode}\r\n        onResendEmail={handleResendEmail}\r\n        {...uiProps}\r\n      />\r\n    );\r\n  }\r\n\r\n  // Step 3: Password reset (only for code method)\r\n  // Use ResetPasswordForm with the obtained resetToken\r\n  return (\r\n    <ResetPasswordForm\r\n      newPassword={newPassword}\r\n      confirmPassword={confirmPassword}\r\n      onNewPasswordChange={setNewPassword}\r\n      onConfirmPasswordChange={setConfirmPassword}\r\n      onSubmit={(e) => void handleResetPasswordSubmit(e)}\r\n      error={error}\r\n      loading={loading}\r\n      success={success}\r\n      authConfig={authConfig}\r\n      {...uiProps}\r\n    />\r\n  );\r\n}\r\n","import { useState, FormEvent } from 'react';\r\nimport { useSearchParams } from '../navigation';\r\nimport { useInsforge } from '../provider/InsforgeProvider';\r\nimport { usePublicAuthConfig } from '../hooks/usePublicAuthConfig';\r\nimport { ResetPasswordForm } from './forms/ResetPasswordForm';\r\nimport { AuthContainer, AuthHeader } from './atoms';\r\nimport { createPasswordSchema } from '../lib/validation';\r\n\r\nexport interface ResetPasswordProps {\r\n  /** Text customization */\r\n  title?: string;\r\n  subtitle?: string;\r\n  newPasswordLabel?: string;\r\n  newPasswordPlaceholder?: string;\r\n  confirmPasswordLabel?: string;\r\n  confirmPasswordPlaceholder?: string;\r\n  submitButtonText?: string;\r\n  loadingButtonText?: string;\r\n\r\n  /** Callback when an error occurs */\r\n  onError?: (error: Error) => void;\r\n}\r\n\r\n/**\r\n * Pre-built reset password page component with full business logic.\r\n *\r\n * Automatically reads the reset token from URL query parameter (?token=xxx).\r\n * Shows an error if token is missing.\r\n