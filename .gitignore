# Dependencies
node_modules/

# Build output
dist/
*.js
*.d.ts
*.js.map
!jest.config.js

# Vercel static output (generated by root build)
public/app/assets/
public/app/*.js
public/app/*.css
public/app/*.map

# Legacy output from earlier portal-at-root builds
public/assets/

# Environment (CRITICAL - never commit)
# Match .env files in root and all subdirectories
**/.env
**/.env.local
**/.env.*.local
**/.env.sofia
.env
.env.local
.env.*.local
.env.sofia

# Sensitive files (CRITICAL - never commit)
key-check.txt
*.key
*.pem
*.p12
testsprite_tests/TEST_CREDENTIALS.md
**/TEST_CREDENTIALS.md

# IDE
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Test artifacts
coverage/
*.log
*.log.*
/tmp/

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Temporary files
*~
*.tmp
*.swp
*.swo

# Audit reports (may contain sensitive data)
audit-reports/*.json
!audit-reports/.gitkeep
.vercel
.env*.local
merchant-portal/artifacts/

# Agent workspace
.agent/
