# Dependencies
node_modules/

# Build output
dist/
*.js
*.d.ts
*.js.map
!jest.config.js

# Vercel static output (generated by root build)
public/app/assets/
public/app/*.js
public/app/*.css
public/app/*.map

# Legacy output from earlier portal-at-root builds
public/assets/

# Environment (CRITICAL - never commit)
# Match .env files in root and all subdirectories
**/.env
**/.env.local
**/.env.*.local
**/.env.sofia
**/.env.function
.env
.env.local
.env.*.local
.env.sofia
.env.function

# Sensitive files (CRITICAL - never commit)
key-check.txt
*.key
*.pem
*.p12
merchant-001-record.json
testsprite_tests/TEST_CREDENTIALS.md
**/TEST_CREDENTIALS.md

# IDE
.idea/
.vscode/tasks.json
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Test artifacts
coverage/
test-results/
