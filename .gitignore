playwright-report/
*.log
*.log.*
/tmp/

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Temporary files
*~
*.tmp
*.swp
*.swo

# Audit reports (may contain sensitive data)
audit-reports/*.json
!audit-reports/.gitkeep
.vercel
.env*.local
merchant-portal/artifacts/

