# ChefIApp Customer Portal - Environment Variables
# Copy this file to .env.local and fill in the values

# =============================================================================
# API
# =============================================================================
VITE_API_URL=http://localhost:4320
VITE_SITE_URL=https://cardapio.chefiapp.com

# =============================================================================
# SUPABASE
# =============================================================================
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# =============================================================================
# SENTRY (Error Monitoring)
# =============================================================================
# Get DSN from: https://sentry.io -> Project Settings -> Client Keys
VITE_SENTRY_DSN=

# For production sourcemap uploads (CI/CD only)
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=chefiapp
# SENTRY_PROJECT=customer-portal

# =============================================================================
# GROWTH & MARKETING
# =============================================================================
# Meta Pixel (Facebook/Instagram Ads)
# Get from: https://business.facebook.com -> Events Manager -> Create Pixel
VITE_META_PIXEL_ID=

# Google Analytics 4
# Get from: https://analytics.google.com -> Admin -> Data Streams
VITE_GA_ID=

# Google Ads Conversion Tracking
# Get from: https://ads.google.com -> Tools -> Conversions
VITE_GOOGLE_ADS_ID=
