{
  "name": "chefiapp-pos-core",
  "version": "1.0.1",
  "packageManager": "pnpm@9.15.0",
  "main": "index.js",
  "workspaces": [
    "merchant-portal",
    "customer-portal",
    "mobile-app"
  ],
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "lint": "npm -w merchant-portal run lint",
    "_test:info": "echo 'Run all tests from repo root with: npm test'",
    "test": "jest",
    "test:unit": "jest tests/unit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:massive": "WORLD_FULL=true jest tests/massive --runInBand --testTimeout=300000",
    "test:pilot": "jest tests/massive --runInBand --testTimeout=60000",
    "test:stress": "WORLD_STRESS=true jest tests/massive --runInBand --testTimeout=600000",
    "truth:scan": "tsx scripts/truth-scan.ts",
    "audit:writes": "npx ts-node scripts/audit-writes.ts",
    "audit:supreme": "npm run test:massive && npm run audit:writes",
    "audit:report": "WORLD_FULL=true jest tests/massive/global.end_to_end.audit.test.ts --runInBand --testTimeout=300000",
    "audit:stress": "WORLD_STRESS=true jest tests/massive/global.end_to_end.audit.test.ts --runInBand --testTimeout=600000",
    "audit:pilot": "jest tests/massive/global.end_to_end.audit.test.ts --runInBand --testTimeout=60000",
    "build": "npm run -s build:core && npm -w merchant-portal run -s build && npm run -s export:portal",
    "build:marketing": "npm -w merchant-portal run -s build:marketing",
    "build:core": "tsc -p tsconfig.json",
    "build:server": "tsc -p tsconfig.server.json",
    "export:portal": "rm -rf public/app && mkdir -p public/app && cp -R merchant-portal/dist/. public/app/",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "server:webhook": "npx ts-node server/webhook-server.ts",
    "server:billing": "npx ts-node server/billing-webhook-server.ts",
    "server:subscription-ui": "npx ts-node server/subscription-management-server.ts",
    "server:web-module": "npx ts-node server/web-module-api-server.ts",
    "server:integration-gateway": "npx ts-node server/integration-gateway.ts",
    "seed:web-module": "npx ts-node server/seed-web-module.ts",
    "refresh:amazon": "npx ts-node server/amazon/refresh-catalog-cli.ts",
    "demo:appstaff": "npx ts-node tests/appstaff-demo-mode.ts",
    "demo:appstaff:one": "bash scripts/demo-one-command.sh",
    "demo:voice": "bash scripts/demo-voice.sh",
    "metrics:appstaff": "npx ts-node tests/appstaff-metrics-extractor.ts",
    "metrics:magic": "npx ts-node tests/appstaff-magic-metrics.ts",
    "demo:freeze": "bash scripts/demo-gold-freeze.sh",
    "audit:a5": "node audit-a5-web-integration.js",
    "audit:a6": "node audit-a6-web-pos-convergence.js",
    "audit:a6:prod": "node audit-a6-production-readiness.js",
    "audit:e": "npm run -s build && node audit-e-web-levels.js",
    "audit:f": "node audit-f-webhook-e2e.js",
    "audit:web-e2e": "npm run audit:twelve-contracts && node scripts/audit-web-e2e.js",
    "audit:four-cores": "node scripts/validate-four-cores.js",
    "audit:twelve-contracts": "node scripts/validate-twelve-contracts.js",
    "audit:router-guard-demo": "node scripts/test-router-guard.js",
    "audit:core": "npm run -s typecheck && npm run -s test",
    "audit:laws": "bash scripts/validate-system-laws.sh",
    "audit:release": "npm run -s audit:web-e2e && npm run -s audit:core && npm run -s audit:laws",
    "audit:release:portal": "npm run -s audit:web-e2e && npm run -s typecheck && npm -w merchant-portal run test -- --run && npm run -s audit:laws",
    "test:truth": "./scripts/test-truth.sh",
    "test:truth:stress": "./scripts/truth-stress.sh",
    "open:apps": "bash scripts/open-all-apps.sh",
    "test:truth:chaos": "./scripts/truth-chaos.sh",
    "audit:360": "./scripts/audit-360.sh",
    "validate:tpv": "npx tsx scripts/validate-tpv-go-nogo.ts",
    "audit:governance": "node scripts/audit-governance.js",
    "audit:governance:update": "node scripts/audit-governance.js --update-baseline",
    "check:ui-guardrails": "node scripts/check-ui-guardrails.mjs",
    "validate:single-entry": "python3 scripts/validate-single-entry-policy.py",
    "validate:tenant-isolation": "./scripts/validate-tenant-isolation.sh",
    "ci:gate:navigation": "./scripts/ci-gate-sovereign-navigation.sh",
    "ci:gate:tenant": "./scripts/validate-tenant-isolation.sh",
    "test:e2e:navigation": "cd merchant-portal && npx playwright test tests/e2e/sovereign-navigation.spec.ts",
    "test:appstaff": "cd merchant-portal && npx vitest run ../tests/nervous-system/AppStaff.stress.test.ts || echo 'AppStaff test file not found, skipping...'",
    "test:all": "npm test && npm run test:appstaff",
    "qr:appstaff-ios": "node scripts/qr-appstaff-ios.mjs",
    "qr:expo-go": "node scripts/qr-expo-go.mjs",
    "kill:5175": "lsof -ti:5175 | xargs kill -9 2>/dev/null || true",
    "vite:up": "bash scripts/vite-persistent.sh",
    "vite:down": "bash scripts/vite-persistent.sh stop",
    "vite:status": "bash scripts/vite-persistent.sh status",
    "start:local": "bash scripts/start-local.sh",
    "expo:go": "cd mobile-app && npx expo start",
    "expo:ios": "cd mobile-app && npx expo run:ios",
    "expo:android": "cd mobile-app && npx expo run:android",
    "start:full": "bash scripts/start-full-stack-with-simulators.sh"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": "npm -w merchant-portal run lint",
    "*.{json,md}": "node -e \"process.exit(0)\""
  },
  "keywords": [],
  "author": "Goldmonkey Empire",
  "license": "ISC",
  "description": "CHEFIAPP POS Core - Event-sourced financial core with legal immutability",
  "dependencies": {
    "@types/pg": "^8.16.0",
    "bootstrap": "^5.3.8",
    "chalk": "^5.6.2",
    "dotenv": "^17.2.3",
    "node-fetch": "^3.3.2",
    "pg": "^8.16.3",
    "react-bootstrap": "^2.10.10",
    "stripe": "^20.1.0",
    "uuid": "^13.0.0",
    "yaml": "^2.8.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.3.1",
    "@commitlint/config-conventional": "^20.3.1",
    "@playwright/test": "^1.49.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@types/uuid": "^10.0.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.2.0",
    "jsdom": "^27.4.0",
    "lint-staged": "^16.2.7",
    "qrcode-terminal": "^0.12.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  }
}
