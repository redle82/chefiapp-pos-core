# Required (critical)
FRONTEND_URL=https://staging.example.com
CORE_URL=https://staging-api.example.com
CORE_ANON_KEY=replace-with-staging-anon-key
RESTAURANT_ID=00000000-0000-0000-0000-000000000100
DESKTOP_DOWNLOAD_BASE=https://downloads.example.com/chefiapp/latest

# Optional desktop filenames
DESKTOP_DOWNLOAD_WINDOWS_FILE=ChefIApp-Desktop-Setup.exe
DESKTOP_DOWNLOAD_MAC_FILE=ChefIApp-Desktop.dmg

# Optional observability endpoint (warn-only)
GATEWAY_URL=https://staging-gateway.example.com

# Optional strict binary validation
# If 0, strict size validation is disabled.
DESKTOP_DOWNLOAD_MIN_BYTES=0

# Optional SHA256 pinning (if set, checksum is validated)
DESKTOP_DOWNLOAD_WINDOWS_SHA256=
DESKTOP_DOWNLOAD_MAC_SHA256=

# Optional custom evidence path
# EVIDENCE_DIR=./tmp/staging-smoke-manual-run
