# ChefIApp Merchant Portal - Environment Variables
# Copy this file to .env.local and fill in the values

# =============================================================================
# DOCKER CORE (backend único)
# =============================================================================
# Produção: URL do Core (PostgREST). Ex.: https://core.chefiapp.com
VITE_CORE_URL=https://your-core.example.com
VITE_CORE_ANON_KEY=your-anon-key

# Docker Core (local): aponta ao Core (PostgREST em 3001). Em dev sem vars usa proxy /rest.
# VITE_CORE_URL=http://localhost:3001
# VITE_CORE_ANON_KEY=chefiapp-core-secret-key-min-32-chars-long

# =============================================================================
# STRIPE (billing: checkout + portal do cliente)
# =============================================================================
# Chave pública (frontend). Chave secreta (STRIPE_SECRET_KEY) em
# Docker secrets ou env vars do servidor.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# ID do preço do plano (Stripe Price ID, ex: price_xxx) para checkout de assinatura
VITE_STRIPE_PRICE_ID=price_xxx

# =============================================================================
# SENTRY (Error Monitoring)
# =============================================================================
# Get DSN from: https://sentry.io -> Project Settings -> Client Keys
VITE_SENTRY_DSN=

# For production sourcemap uploads (CI/CD only)
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=chefiapp
# SENTRY_PROJECT=merchant-portal

# =============================================================================
# DEBUG — Vertical slice brutal (temporário; NUNCA em produção)
# =============================================================================
# Quando true: TPV/KDS/Dashboard ignoram Turno, ORE, Wizard. Leitura/escrita direta
# (create_order_atomic → gm_orders → KDS/Dashboard leem direto). Para provar que o
# sistema ainda respira. Ver docs/pilots/VERTICAL_SLICE_DEBUG_DIRECT_FLOW.md
# VITE_DEBUG_DIRECT_FLOW=true

# =============================================================================
# Dashboard — Control Plane (OPERATIONAL_DASHBOARD_V2_CONTRACT)
# =============================================================================
# Por defeito o dashboard usa OPERATIONAL_OS (Painel de Comando). Para layout legado: VITE_UI_MODE=default
# Ver docs/contracts/OPERATIONAL_DASHBOARD_V2_CONTRACT.md
# VITE_UI_MODE=default

# Trilho de instalação de terminais (gm_terminals, device_id). false = TPV/KDS "Não instalado" + CTA.
# VITE_TERMINAL_INSTALLATION_TRACK=false

# =============================================================================
# E2E (opcional)
# =============================================================================
# Base URL para Playwright (fase-b-teste-humano.spec.ts). Default: http://localhost:5175
# Para validar contra URL real: E2E_BASE_URL=https://tua-app.vercel.app
# E2E_BASE_URL=
