# ChefIApp Merchant Portal - Environment Variables
# Copy this file to .env.local and fill in the values

# =============================================================================
# SUPABASE
# =============================================================================
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# =============================================================================
# STRIPE (billing: checkout + portal do cliente)
# =============================================================================
# Chave pública (frontend). Chave secreta (STRIPE_SECRET_KEY) em Supabase:
# Dashboard → Project Settings → Edge Functions → Secrets
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# ID do preço do plano (Stripe Price ID, ex: price_xxx) para checkout de assinatura
VITE_STRIPE_PRICE_ID=price_xxx

# =============================================================================
# SENTRY (Error Monitoring)
# =============================================================================
# Get DSN from: https://sentry.io -> Project Settings -> Client Keys
VITE_SENTRY_DSN=

# For production sourcemap uploads (CI/CD only)
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=chefiapp
# SENTRY_PROJECT=merchant-portal
