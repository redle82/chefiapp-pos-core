# Merchant Portal (Vite) example env
# Copy to .env.local and fill values.
# NOTE: Vite only exposes env vars prefixed with VITE_.

# Web Module API base URL
VITE_API_BASE=http://localhost:4320

# Internal token for /internal/* endpoints (dev only)
VITE_INTERNAL_API_TOKEN=dev-token

# Wizard target restaurant ID (UUID)
VITE_RESTAURANT_ID=

# Optional: demo helper (1-click test order)
VITE_MENU_ITEM_ID=

# Optional: default public page slug (used for the iframe/link)
VITE_DEFAULT_SLUG=sofia-gastrobar

# Optional: Stripe keys for the wizard Stripe connect step
VITE_STRIPE_PK=
VITE_STRIPE_SK=
VITE_STRIPE_WHSEC=
