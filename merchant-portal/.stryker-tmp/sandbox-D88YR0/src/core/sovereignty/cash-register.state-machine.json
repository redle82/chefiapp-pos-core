{
    "id": "cash_register",
    "initial": "closed",
    "context": {
        "restaurant_id": null,
        "name": "Caixa Principal",
        "opening_balance_cents": 0,
        "closing_balance_cents": null,
        "total_sales_cents": 0,
        "opened_by": null,
        "closed_by": null,
        "opened_at": null,
        "closed_at": null
    },
    "states": {
        "closed": {
            "on": {
                "OPEN": {
                    "target": "open",
                    "actions": [
                        "setOpenedBy",
                        "setOpeningBalance",
                        "setTimestamp",
                        "persistOpenCashRegister"
                    ]
                }
            }
        },
        "open": {
            "on": {
                "CLOSE": {
                    "target": "closed",
                    "actions": [
                        "setClosedBy",
                        "setClosingBalance",
                        "calculateTotalSales",
                        "setTimestamp"
                    ]
                }
            }
        }
    }
}