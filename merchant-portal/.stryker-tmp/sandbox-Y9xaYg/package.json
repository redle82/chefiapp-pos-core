{
  "name": "merchant-portal",
  "private": true,
  "version": "1.0.1",
  "type": "module",
  "scripts": {
    "check:env": "tsx scripts/check-env.ts",
    "dev": "pnpm run check:env && vite",
    "validate:constitution": "node ../scripts/validate-constitution.mjs",
    "prebuild": "npm run validate:constitution",
    "build": "vite build",
    "build:marketing": "vite build --config vite.config.marketing.ts",
    "lint": "eslint . --max-warnings 9999 --no-warn-ignored",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:hardening": "bash ../scripts/core/run-hardening-tests.sh",
    "test:e2e": "playwright test",
    "e2e:critical": "playwright test tests/e2e/critical-flow.spec.ts",
    "test:e2e:smoke": "playwright test tests/e2e/fluxo-total.spec.ts tests/e2e/fase-b-teste-humano.spec.ts tests/e2e/fase-a-global-tecnico.spec.ts",
    "type-check": "tsc --noEmit",
    "genesis:prove": "npx tsx scripts/genesis-prove.ts",
    "genesis:verify": "npx tsx scripts/genesis-verify.ts",
    "audit:architecture": "node scripts/audit-architecture.cjs",
    "audit:domain": "node scripts/audit-domain.cjs",
    "audit:core-domain": "bash ../scripts/check-financial-supabase.sh",
    "audit:all": "npm run audit:architecture && npm run audit:domain",
    "mobile:sync": "bash fix-capacitor-paths.sh && npm run build && npx cap sync",
    "mobile:ios": "npx cap open ios",
    "mobile:android": "npx cap open android",
    "mobile:run:ios": "npx cap run ios",
    "mobile:run:android": "npx cap run android",
    "mutation:test": "npx stryker run && echo '✅ Mutation testing complete'",
    "mutation:test:quick": "npx stryker run stryker.quick.config.mjs && echo '✅ Quick scan complete'",
    "mutation:test:baseline": "npm run mutation:test && cp artifacts/mutation-report.json artifacts/mutation-baseline.json && echo '✅ Baseline saved'",
    "mutation:test:baseline:quick": "npm run mutation:test:quick && cp artifacts/mutation-report.json artifacts/mutation-baseline.quick.json && echo '✅ Quick baseline saved'",
    "postinstall": "bash fix-capacitor-paths.sh 2>/dev/null || true"
  },
  "dependencies": {
    "@capacitor-mlkit/barcode-scanning": "^8.0.0",
    "@capacitor/android": "^8.0.1",
    "@capacitor/core": "^8.0.1",
    "@capacitor/ios": "^8.0.1",
    "@capgo/capacitor-native-biometric": "^8.3.1",
    "@capgo/capacitor-nfc": "^8.0.6",
    "@chefiapp/core-design-system": "file:../core-design-system",
    "@emotion/is-prop-valid": "^1.4.0",
    "@insforge/sdk": "^1.1.5",
    "@stripe/react-stripe-js": "^5.4.1",
    "@stripe/stripe-js": "^8.6.0",
    "@types/uuid": "^10.0.0",
    "buffer": "^6.0.3",
    "dotenv": "^17.2.3",
    "framer-motion": "^12.23.26",
    "i18next": "^25.8.7",
    "idb": "^8.0.3",
    "lucide-react": "^0.562.0",
    "papaparse": "^5.5.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-helmet-async": "^2.0.5",
    "react-i18next": "^16.5.4",
    "react-qr-code": "^2.0.18",
    "react-router-dom": "^7.11.0",
    "recharts": "^3.6.0",
    "sileo": "^0.1.0",
    "uuid": "^13.0.0",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.0.1",
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.57.0",
    "@stryker-mutator/core": "^9.5.1",
    "@stryker-mutator/typescript-checker": "^9.5.1",
    "@tailwindcss/vite": "^4.1.18",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/papaparse": "^5.5.2",
    "@types/pg": "^8.16.0",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^27.4.0",
    "pg": "^8.16.3",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.16",
    "workbox-window": "^7.0.0"
  }
}
