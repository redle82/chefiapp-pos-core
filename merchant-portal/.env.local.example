# ChefIApp Merchant Portal - Local Development Environment
# Copy this file to .env.local for local development
#
# ⚠️ CRITICAL: This file contains LOCAL credentials only
# Never commit .env.local to git - it's in .gitignore
#
# Referência única de variáveis: docs/ops/ENV_MATRIX.md (Stack 2026)

# =============================================================================
# INSFORGE (Production BaaS) — Leave empty for local Docker Core dev
# =============================================================================
# When set, InsForge replaces Docker Core as the backend.
# VITE_INSFORGE_URL=https://vv5bwyz6.us-east.insforge.app
# VITE_INSFORGE_ANON_KEY=your-insforge-anon-key

# =============================================================================
# DOCKER CORE (Local Development)
# =============================================================================
# Docker Core local (PostgREST em 3001). Em dev sem vars o Vite usa proxy /rest.
# Se definires VITE_SUPABASE_* com URL supabase.co, o portal usa Supabase como CORE (fluxo soberano P0).
VITE_CORE_URL=http://localhost:3001
VITE_CORE_ANON_KEY=chefiapp-core-secret-key-min-32-chars-long

# =============================================================================
# SUPABASE (Fluxo soberano P0 — login email/password, mesmo backend do seed)
# =============================================================================
# Quando definido com URL que contém supabase.co, substitui CORE acima para auth e PostgREST.
# Descomenta e preenche para validar P0.2 (owner seeded, restaurante real no Admin).
# VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
# Bypass 400 (disabled_at): true = não chama gm_restaurant_members/gm_restaurants, usa seed. Só dev.
# VITE_SUPABASE_SKIP_RESTAURANT_API=true

# API base: local = integration-gateway (dev); production = Supabase Edge URL.
# Local: pnpm run dev:gateway (port 4320). Production: https://<PROJECT_REF>.supabase.co/functions/v1
# Ver docs/ops/ENV_MATRIX.md e docs/ops/MIGRATION_RENDER_TO_EDGE.md
VITE_API_BASE=http://localhost:4320
# Token interno; debe coincidir con INTERNAL_API_TOKEN del gateway
VITE_INTERNAL_API_TOKEN=chefiapp-internal-token-dev

# =============================================================================
# KEYCLOAK (Local Development)
# =============================================================================
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=chefiapp
VITE_KEYCLOAK_CLIENT_ID=merchant-portal

# =============================================================================
# AUTH (Local Development)
# =============================================================================
# Default false. Set true only when you need mock auth in local dev.
# VITE_ALLOW_MOCK_AUTH=true

# =============================================================================
# SOFIA OPERACIONAL (Docker/Core — ambiente de validação oficial)
# =============================================================================
# Para ver "Sofia Gastrobar" e sessão ativa na topbar (evitar "Restaurante" / "Sessão encerrada"):
#   VITE_ALLOW_MOCK_AUTH=true
#   VITE_DEBUG_DIRECT_FLOW=true
# Opcional: esconder banner "Modo demonstração":
#   VITE_FORCE_PRODUCT_MODE=live
# Runbook: docs/ops/SOFIA_GASTROBAR_AMBIENTE_OPERACIONAL_RUNBOOK.md
# VITE_ALLOW_MOCK_AUTH=true
# VITE_DEBUG_DIRECT_FLOW=true
# VITE_FORCE_PRODUCT_MODE=live

# =============================================================================
# STRIPE (Local Development - Use test keys)
# =============================================================================
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# =============================================================================
# APPSTAFF — Role por query (abas paralelas)
# =============================================================================
# true (default): permite ?role= em /app/staff (DEMO/PILOT/LOCAL).
# false: em produção pode desativar; role só por tab storage ou login.
# Ref: docs/architecture/APPSTAFF_RUNTIME_MODEL.md
# VITE_ALLOW_STAFF_ROLE_QUERY=true

# =============================================================================
# TPV DESKTOP — Download na tela Admin > TPV (opcional)
# =============================================================================
# Só quando existir uma release publicada (ficheiros .dmg/.exe num URL).
# Ver: docs/ops/TPV_RELEASE_DOWNLOAD.md
# VITE_DESKTOP_DOWNLOAD_BASE=https://github.com/ORG/REPO/releases/download/v1.0.0
# VITE_DESKTOP_DOWNLOAD_MAC_FILE=ChefIApp-Desktop.dmg
# VITE_DESKTOP_DOWNLOAD_WINDOWS_FILE=ChefIApp-Desktop-Setup.exe
# VITE_DESKTOP_RELEASE_VERSION=1.0.0

# =============================================================================
# SENTRY (Optional - Leave empty for local dev)
# =============================================================================
VITE_SENTRY_DSN=
