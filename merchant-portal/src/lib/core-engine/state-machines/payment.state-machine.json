{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "name": "PAYMENT",
  "description": "Payment state machine - financial transaction against an order",
  "initial": "PENDING",
  "states": {
    "PENDING": {
      "description": "Payment initiated, awaiting confirmation",
      "transitions": {
        "CONFIRM": {
          "target": "CONFIRMED",
          "description": "Payment processed successfully",
          "guards": [
            "paymentOrderIsLocked"
          ],
          "effects": [
            "markIrreversible"
          ]
        },
        "FAIL": {
          "target": "FAILED",
          "description": "Payment processing failed"
        },
        "CANCEL": {
          "target": "CANCELED",
          "description": "Payment canceled"
        }
      }
    },
    "CONFIRMED": {
      "description": "Payment successfully processed",
      "terminal": true
    },
    "FAILED": {
      "description": "Payment processing failed",
      "transitions": {
        "RETRY": {
          "target": "PENDING",
          "description": "Retry payment"
        }
      }
    },
    "CANCELED": {
      "description": "Payment canceled before confirmation",
      "transitions": {
        "RETRY": {
          "target": "PENDING",
          "description": "Retry payment"
        }
      }
    }
  },
  "events": {
    "CONFIRM": "Confirm payment",
    "FAIL": "Mark payment as failed",
    "CANCEL": "Cancel payment",
    "RETRY": "Retry payment"
  },
  "effects": {
    "markIrreversible": {
      "description": "Mark payment as irreversible",
      "type": "data-mutation"
    }
  }
}

