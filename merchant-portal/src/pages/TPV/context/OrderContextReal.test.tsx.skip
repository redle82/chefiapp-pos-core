
import { render, screen, act, waitFor } from '@testing-library/react';
import { describe, it, expect, vi, beforeEach } from 'vitest';
import React from 'react';
import { OrderProvider, OrderContext } from './OrderContextReal';
import { supabase } from '../../../core/supabase';
import { Logger } from '../../../core/logger';

// Mocks
vi.mock('../../../core/supabase', () => ({
    supabase: {
        auth: {
            getUser: vi.fn().mockResolvedValue({ data: { user: { id: 'test-user' } } })
        },
        channel: vi.fn(),
        removeChannel: vi.fn(),
        from: vi.fn(() => ({
            select: vi.fn(() => ({
                eq: vi.fn().mockResolvedValue({ data: [], error: null })
            }))
        }))
    }
}));

vi.mock('../../../core/logger', () => ({
    Logger: {
        info: vi.fn(),
        warn: vi.fn(),
        error: vi.fn(),
        critical: vi.fn(),
        setContext: vi.fn(),
    }
}));

vi.mock('../../../core/tpv/OrderEngine', () => ({
    OrderEngine: {
        getActiveOrders: vi.fn().mockResolvedValue([]),
    }
}));

vi.mock('./OfflineOrderContext', () => ({
    useOfflineOrder: vi.fn().mockReturnValue({
        isOffline: false,
        addToQueue: vi.fn(),
        queue: []
    })
}));

// Mock EventStore to avoid IndexedDB dependency
vi.mock('../../../core/events/EventStore', () => ({
    EventStore: vi.fn().mockImplementation(() => ({
        append: vi.fn(),
        getAll: vi.fn().mockResolvedValue([]),
        getByStream: vi.fn().mockResolvedValue([])
    }))
}));

describe('OrderContextReal', () => {
    beforeEach(() => {
        vi.clearAllMocks();
        localStorage.clear();
        localStorage.setItem('chefiapp_restaurant_id', 'test-restaurant');
    });

    it('subscribes to realtime channel on mount', async () => {
        const subscribeMock = vi.fn();
        const onMock = vi.fn().mockReturnValue({ subscribe: subscribeMock });
        const channelMock = vi.fn().mockReturnValue({ on: onMock });
        (supabase.channel as any).mockImplementation(channelMock);

        render(
            <OrderProvider>
                <div>Test</div>
            </OrderProvider>
        );

        await waitFor(() => {
            expect(supabase.channel).toHaveBeenCalledWith('orders_realtime_test-restaurant');
            expect(onMock).toHaveBeenCalledWith(
                'postgres_changes',
                expect.objectContaining({ event: '*', table: 'gm_orders' }),
                expect.any(Function)
            );
            expect(subscribeMock).toHaveBeenCalled();
        });

        expect(Logger.info).toHaveBeenCalledWith(
            'Setting up Realtime & Polling',
            expect.objectContaining({ context: 'OrderContext' })
        );
    });

    it('logs realtime events', async () => {
        let eventCallback: any;
        const onMock = vi.fn().mockImplementation((event, filter, callback) => {
            if (event === 'postgres_changes') {
                eventCallback = callback;
            }
            return { subscribe: vi.fn() };
        });
        (supabase.channel as any).mockReturnValue({ on: onMock });

        render(
            <OrderProvider>
                <div>Test</div>
            </OrderProvider>
        );

        await waitFor(() => expect(eventCallback).toBeDefined());

        // Simulate Realtime Event
        act(() => {
            eventCallback({ eventType: 'INSERT', new: { id: '123' } });
        });

        expect(Logger.info).toHaveBeenCalledWith(
            'Realtime event received',
            expect.objectContaining({ eventType: 'INSERT' })
        );
    });
});
