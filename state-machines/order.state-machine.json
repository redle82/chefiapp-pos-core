{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "name": "ORDER",
  "description": "Order state machine - groups consumption items for table or customer",
  "initial": "OPEN",
  "states": {
    "OPEN": {
      "description": "Order created, accepting items",
      "transitions": {
        "FINALIZE": {
          "target": "LOCKED",
          "description": "Finalize order (calculate totals, no more items)",
          "guards": [
            "orderIsOpen",
            "orderHasItems"
          ],
          "effects": [
            "calculateTotal",
            "lockItems"
          ]
        },
        "CANCEL": {
          "target": "CANCELED",
          "description": "Cancel order before finalization"
        }
      }
    },
    "LOCKED": {
      "description": "Order finalized, total calculated (immutable)",
      "transitions": {
        "PAY": {
          "target": "PAID",
          "description": "Payment confirmed",
          "guards": [
            "hasConfirmedPayment"
          ]
        },
        "CANCEL": {
          "target": "CANCELED",
          "description": "Cancel order"
        }
      }
    },
    "PAID": {
      "description": "Payment confirmed",
      "transitions": {
        "CLOSE": {
          "target": "CLOSED",
          "description": "Operation terminated"
        }
      }
    },
    "CLOSED": {
      "description": "Operation terminated",
      "terminal": true
    },
    "CANCELED": {
      "description": "Order canceled before payment",
      "terminal": true
    }
  },
  "events": {
    "FINALIZE": "Finalize order",
    "PAY": "Confirm payment",
    "CLOSE": "Close operation",
    "CANCEL": "Cancel order"
  },
  "guards": {
    "hasConfirmedPayment": {
      "description": "Order must have at least one CONFIRMED payment",
      "type": "business-rule"
    }
  },
  "effects": {
    "calculateTotal": {
      "description": "Calculate and set order total (immutable after)",
      "type": "data-mutation"
    },
    "lockItems": {
      "description": "Prevent further item modifications",
      "type": "data-mutation"
    }
  }
}

